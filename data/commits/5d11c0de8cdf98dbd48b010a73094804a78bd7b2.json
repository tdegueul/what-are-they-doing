      "contents_url": "https://api.github.com/repos/tenzir/tenzir/contents/test%2Ftests%2Foperators%2Freplace%2Freplace-sliced-array.tql?ref=5d11c0de8cdf98dbd48b010a73094804a78bd7b2",
      "patch": "@@ -0,0 +1,6 @@\n+// Test replace on sliced arrays (arrays with non-zero offsets).\n+// This validates that null bitmap mutation works correctly when\n+// the underlying array has been sliced (e.g., via tail/head).\n+from {x: null, y: \"a\"}, {x: \"b\", y: \"a\"}, {x: \"a\", y: \"c\"}\n+tail 2\n+replace what=\"a\", with=null"
