{
  "message": "Fix crash in replace operator with immutable null bitmaps\n\nThe replace operator crashed when processing arrays with immutable null\nbitmaps (e.g., from ocsf::cast) because Arrow buffers from array->null_bitmap()\nare typically immutable. Use arrow::internal::CopyBitmap() to ensure mutability,\nfollowing the pattern from series.cpp.\n\nCo-Authored-By: Claude Opus 4.5 <noreply@anthropic.com>",
  "files": [
    {
      "sha": "d0f1827da6cd6d591b14aa478a9468bfbf77580d",
      "filename": "libtenzir/builtins/operators/replace.cpp",
      "status": "modified",
      "additions": 11,
      "deletions": 2,
      "changes": 13,
      "blob_url": "https://github.com/tenzir/tenzir/blob/5d11c0de8cdf98dbd48b010a73094804a78bd7b2/libtenzir%2Fbuiltins%2Foperators%2Freplace.cpp",
      "raw_url": "https://github.com/tenzir/tenzir/raw/5d11c0de8cdf98dbd48b010a73094804a78bd7b2/libtenzir%2Fbuiltins%2Foperators%2Freplace.cpp",
      "contents_url": "https://api.github.com/repos/tenzir/tenzir/contents/libtenzir%2Fbuiltins%2Foperators%2Freplace.cpp?ref=5d11c0de8cdf98dbd48b010a73094804a78bd7b2",
      "patch": "@@ -7,6 +7,7 @@\n // SPDX-License-Identifier: BSD-3-Clause\n \n #include \"tenzir/argument_parser2.hpp\"\n+#include \"tenzir/arrow_memory_pool.hpp\"\n #include \"tenzir/arrow_table_slice.hpp\"\n #include \"tenzir/arrow_utils.hpp\"\n #include \"tenzir/collect.hpp\"\n@@ -202,9 +203,17 @@ auto replace_series_with_null(const basic_series<record_type>& input,\n     const auto& array_data = array->data();\n     const auto offset = array_data->offset;\n     const auto total_count = array_data->length + offset;\n-    auto null_bitmap = array->null_bitmap();\n-    if (not null_bitmap) {\n+    auto null_bitmap = std::shared_ptr<arrow::Buffer>{};\n+    if (array->null_bitmap_data()) {\n+      // Copy the existing bitmap to ensure mutability.\n+      // Copy from position 0 to total_count to preserve offset-based indexing.\n+      null_bitmap = check(arrow::internal::CopyBitmap(\n+        arrow_memory_pool(), array->null_bitmap_data(), 0, total_count));\n+    } else {\n+      // No existing bitmap - allocate a fresh one and set all bits to valid.\n       null_bitmap = check(arrow::AllocateEmptyBitmap(total_count));\n+      arrow::bit_util::SetBitsTo(null_bitmap->mutable_data(), 0, total_count,\n+                                 true);\n     }\n     TENZIR_ASSERT(null_bitmap->size()\n                   >= arrow::bit_util::BytesForBits(total_count));"
    },
    {
