{
  "message": "Fix ANSI color output when run via curl | bash\n\nColor variables were defined with single quotes (RED='\\033[0;31m'),\nstoring literal backslash-zero-three-three characters. echo -e was\nsupposed to interpret them at output time, but this fails in certain\nbash-from-pipe contexts.\n\nSwitch to $'...' ANSI-C quoting (RED=$'\\033[0;31m') which embeds\nthe actual escape byte at assignment time. Now printf and echo both\nproduce correct ANSI output regardless of how bash was invoked.\n\nCo-Authored-By: Claude Opus 4.5 <noreply@anthropic.com>",
  "files": [
    {
      "sha": "55e1696e35cad1fe06736c9ce0cf3fdc2a76a5ec",
      "filename": "install-post-compact-reminder.sh",
      "status": "modified",
      "additions": 12,
      "deletions": 12,
      "changes": 24,
      "blob_url": "https://github.com/Dicklesworthstone/post_compact_reminder/blob/e5009dfed7e2530229168dd3bf9a7dfee6939b1d/install-post-compact-reminder.sh",
      "raw_url": "https://github.com/Dicklesworthstone/post_compact_reminder/raw/e5009dfed7e2530229168dd3bf9a7dfee6939b1d/install-post-compact-reminder.sh",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/post_compact_reminder/contents/install-post-compact-reminder.sh?ref=e5009dfed7e2530229168dd3bf9a7dfee6939b1d",
      "patch": "@@ -79,18 +79,18 @@ acquire_lock() {\n # -----------------------------------------------------------------------------\n # Colors and Styles\n # -----------------------------------------------------------------------------\n-RED='\\033[0;31m'\n-GREEN='\\033[0;32m'\n-YELLOW='\\033[1;33m'\n-BLUE='\\033[0;34m'\n-CYAN='\\033[0;36m'\n-MAGENTA='\\033[0;35m'\n-WHITE='\\033[1;37m'\n-BOLD='\\033[1m'\n-DIM='\\033[2m'\n-ITALIC='\\033[3m'\n-UNDERLINE='\\033[4m'\n-NC='\\033[0m'\n+RED=$'\\033[0;31m'\n+GREEN=$'\\033[0;32m'\n+YELLOW=$'\\033[1;33m'\n+BLUE=$'\\033[0;34m'\n+CYAN=$'\\033[0;36m'\n+MAGENTA=$'\\033[0;35m'\n+WHITE=$'\\033[1;37m'\n+BOLD=$'\\033[1m'\n+DIM=$'\\033[2m'\n+ITALIC=$'\\033[3m'\n+UNDERLINE=$'\\033[4m'\n+NC=$'\\033[0m'\n \n # Box drawing characters (rounded corners)\n BOX_TL='\u256d' BOX_TR='\u256e' BOX_BL='\u2570' BOX_BR='\u256f'"
    }
