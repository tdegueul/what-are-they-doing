      "contents_url": "https://api.github.com/repos/prime-radiant-inc/stockyard/contents/pkg%2Fdashboard%2Ftemplates%2F_head.html?ref=586fdf9adf898a828fede063e3bba9ff09c011ef",
      "patch": "@@ -0,0 +1,13 @@\n+{{define \"head\"}}\n+<head>\n+    <meta charset=\"UTF-8\">\n+    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n+    <title>{{if .Title}}{{.Title}} - {{end}}Stockyard</title>\n+    <script src=\"/static/js/htmx.min.js\"></script>\n+    <script defer src=\"/static/js/alpine.min.js\"></script>\n+    <script src=\"/static/js/tailwind.min.js\"></script>\n+    <style>\n+        [x-cloak] { display: none !important; }\n+    </style>\n+</head>\n+{{end}}"
