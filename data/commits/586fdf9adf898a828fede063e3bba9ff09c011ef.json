      "blob_url": "https://github.com/prime-radiant-inc/stockyard/blob/586fdf9adf898a828fede063e3bba9ff09c011ef/pkg%2Fdashboard%2Ftemplates%2F_layout_start.html",
      "raw_url": "https://github.com/prime-radiant-inc/stockyard/raw/586fdf9adf898a828fede063e3bba9ff09c011ef/pkg%2Fdashboard%2Ftemplates%2F_layout_start.html",
      "contents_url": "https://api.github.com/repos/prime-radiant-inc/stockyard/contents/pkg%2Fdashboard%2Ftemplates%2F_layout_start.html?ref=586fdf9adf898a828fede063e3bba9ff09c011ef",
      "patch": "@@ -0,0 +1,13 @@\n+{{define \"layout-start\"}}\n+<!DOCTYPE html>\n+<html lang=\"en\">\n+{{template \"head\" .}}\n+<body class=\"bg-gray-50 text-gray-900 h-screen flex flex-col\"\n+      x-data=\"{showSidebar: window.innerWidth >= 1024}\"\n+      @resize.window=\"showSidebar = window.innerWidth >= 1024\">\n+    {{template \"header\" .}}\n+    <div class=\"flex flex-1 overflow-hidden\">\n+        {{template \"mobile-backdrop\"}}\n+        {{template \"sidebar\" .}}\n+        <main class=\"flex-1 overflow-auto p-6\">\n+{{end}}"
    },
    {
      "sha": "1f29c23889f695c89eddfb0d1e6b77fb4ca048a2",
      "filename": "pkg/dashboard/templates/_mobile_backdrop.html",
      "status": "added",
      "additions": 13,
      "deletions": 0,
      "changes": 13,
      "blob_url": "https://github.com/prime-radiant-inc/stockyard/blob/586fdf9adf898a828fede063e3bba9ff09c011ef/pkg%2Fdashboard%2Ftemplates%2F_mobile_backdrop.html",
      "raw_url": "https://github.com/prime-radiant-inc/stockyard/raw/586fdf9adf898a828fede063e3bba9ff09c011ef/pkg%2Fdashboard%2Ftemplates%2F_mobile_backdrop.html",
      "contents_url": "https://api.github.com/repos/prime-radiant-inc/stockyard/contents/pkg%2Fdashboard%2Ftemplates%2F_mobile_backdrop.html?ref=586fdf9adf898a828fede063e3bba9ff09c011ef",
      "patch": "@@ -0,0 +1,13 @@\n+{{define \"mobile-backdrop\"}}\n+<!-- Mobile sidebar backdrop -->\n+<div x-show=\"showSidebar && window.innerWidth < 1024\"\n+     x-transition:enter=\"transition-opacity ease-out duration-200\"\n+     x-transition:enter-start=\"opacity-0\"\n+     x-transition:enter-end=\"opacity-100\"\n+     x-transition:leave=\"transition-opacity ease-in duration-150\"\n+     x-transition:leave-start=\"opacity-100\"\n+     x-transition:leave-end=\"opacity-0\"\n+     @click=\"showSidebar = false\"\n+     class=\"lg:hidden fixed inset-0 bg-black bg-opacity-50 z-30\"\n+     x-cloak></div>\n+{{end}}"
    },
