    {
      "sha": "8d72beb1a4069545f4c57e5390abdb73415c1b69",
      "filename": "pkg/dashboard/templates/_header.html",
      "status": "added",
      "additions": 23,
      "deletions": 0,
      "changes": 23,
      "blob_url": "https://github.com/prime-radiant-inc/stockyard/blob/586fdf9adf898a828fede063e3bba9ff09c011ef/pkg%2Fdashboard%2Ftemplates%2F_header.html",
      "raw_url": "https://github.com/prime-radiant-inc/stockyard/raw/586fdf9adf898a828fede063e3bba9ff09c011ef/pkg%2Fdashboard%2Ftemplates%2F_header.html",
      "contents_url": "https://api.github.com/repos/prime-radiant-inc/stockyard/contents/pkg%2Fdashboard%2Ftemplates%2F_header.html?ref=586fdf9adf898a828fede063e3bba9ff09c011ef",
      "patch": "@@ -0,0 +1,23 @@\n+{{define \"header\"}}\n+<header class=\"bg-white border-b border-gray-200 px-4 py-2 flex items-center justify-between\">\n+    <div class=\"flex items-center gap-4\">\n+        <!-- Mobile hamburger menu -->\n+        <button @click=\"showSidebar = !showSidebar\" class=\"lg:hidden p-2 hover:bg-gray-100 rounded\">\n+            <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6h16M4 12h16M4 18h16\"/>\n+            </svg>\n+        </button>\n+        <span class=\"font-semibold text-lg\">Stockyard</span>\n+    </div>\n+    <div class=\"flex items-center gap-2\">\n+        {{if .UserAvatar}}\n+        <img src=\"{{.UserAvatar}}\" alt=\"{{.User}}\" class=\"w-8 h-8 rounded-full\">\n+        {{else}}\n+        <div class=\"w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center text-white text-sm font-bold uppercase\">\n+            {{if .User}}{{slice .User 0 1}}{{else}}?{{end}}\n+        </div>\n+        {{end}}\n+        <span class=\"text-sm text-gray-600 hidden sm:inline\">{{.User}}</span>\n+    </div>\n+</header>\n+{{end}}"
    },
