      "raw_url": "https://github.com/teamchong/metal0/raw/979759f2733512432f9731f875f6ac0cc8767d44/packages%2Ftoken_optimizer%2Fsrc%2Ffont_3x4.zig",
      "contents_url": "https://api.github.com/repos/teamchong/metal0/contents/packages%2Ftoken_optimizer%2Fsrc%2Ffont_3x4.zig?ref=979759f2733512432f9731f875f6ac0cc8767d44",
      "patch": "@@ -0,0 +1,113 @@\n+const std = @import(\"std\");\n+\n+// 3\u00d74 nanofont for ASCII characters\n+// Smallest readable bitmap font - optimized for token compression\n+// Each character is 3 pixels wide \u00d7 4 pixels tall = 12 bits\n+\n+pub const Font3x4 = struct {\n+    width: usize = 3,\n+    height: usize = 4,\n+\n+    pub fn getGlyph(self: Font3x4, char: u8) [4]u8 {\n+        _ = self;\n+        return switch (char) {\n+            ' ' => .{ 0b000, 0b000, 0b000, 0b000 },\n+            'A' => .{ 0b010, 0b101, 0b111, 0b101 },\n+            'B' => .{ 0b110, 0b111, 0b111, 0b110 },\n+            'C' => .{ 0b011, 0b100, 0b100, 0b011 },\n+            'D' => .{ 0b110, 0b101, 0b101, 0b110 },\n+            'E' => .{ 0b111, 0b110, 0b110, 0b111 },\n+            'F' => .{ 0b111, 0b110, 0b110, 0b100 },\n+            'G' => .{ 0b011, 0b100, 0b101, 0b011 },\n+            'H' => .{ 0b101, 0b111, 0b111, 0b101 },\n+            'I' => .{ 0b111, 0b010, 0b010, 0b111 },\n+            'J' => .{ 0b011, 0b001, 0b101, 0b010 },\n+            'K' => .{ 0b101, 0b110, 0b110, 0b101 },\n+            'L' => .{ 0b100, 0b100, 0b100, 0b111 },\n+            'M' => .{ 0b101, 0b111, 0b101, 0b101 },\n+            'N' => .{ 0b101, 0b111, 0b111, 0b101 },\n+            'O' => .{ 0b010, 0b101, 0b101, 0b010 },\n+            'P' => .{ 0b110, 0b111, 0b110, 0b100 },\n+            'Q' => .{ 0b010, 0b101, 0b111, 0b011 },\n+            'R' => .{ 0b110, 0b111, 0b110, 0b101 },\n+            'S' => .{ 0b011, 0b010, 0b010, 0b110 },\n+            'T' => .{ 0b111, 0b010, 0b010, 0b010 },\n+            'U' => .{ 0b101, 0b101, 0b101, 0b010 },\n+            'V' => .{ 0b101, 0b101, 0b101, 0b010 },\n+            'W' => .{ 0b101, 0b101, 0b111, 0b101 },\n+            'X' => .{ 0b101, 0b010, 0b010, 0b101 },\n+            'Y' => .{ 0b101, 0b010, 0b010, 0b010 },\n+            'Z' => .{ 0b111, 0b001, 0b010, 0b111 },\n+            'a' => .{ 0b000, 0b011, 0b101, 0b011 },\n+            'b' => .{ 0b100, 0b110, 0b101, 0b110 },\n+            'c' => .{ 0b000, 0b011, 0b100, 0b011 },\n+            'd' => .{ 0b001, 0b011, 0b101, 0b011 },\n+            'e' => .{ 0b000, 0b010, 0b111, 0b011 },\n+            'f' => .{ 0b011, 0b100, 0b110, 0b100 },\n+            'g' => .{ 0b011, 0b101, 0b011, 0b110 },\n+            'h' => .{ 0b100, 0b110, 0b101, 0b101 },\n+            'i' => .{ 0b010, 0b000, 0b010, 0b010 },\n+            'j' => .{ 0b001, 0b000, 0b001, 0b110 },\n+            'k' => .{ 0b100, 0b101, 0b110, 0b101 },\n+            'l' => .{ 0b010, 0b010, 0b010, 0b010 },\n+            'm' => .{ 0b000, 0b111, 0b111, 0b101 },\n+            'n' => .{ 0b000, 0b110, 0b101, 0b101 },\n+            'o' => .{ 0b000, 0b010, 0b101, 0b010 },\n+            'p' => .{ 0b000, 0b110, 0b111, 0b100 },\n+            'q' => .{ 0b000, 0b011, 0b111, 0b001 },\n+            'r' => .{ 0b000, 0b011, 0b100, 0b100 },\n+            's' => .{ 0b000, 0b011, 0b010, 0b110 },\n+            't' => .{ 0b010, 0b111, 0b010, 0b011 },\n+            'u' => .{ 0b000, 0b101, 0b101, 0b011 },\n+            'v' => .{ 0b000, 0b101, 0b101, 0b010 },\n+            'w' => .{ 0b000, 0b101, 0b111, 0b111 },\n+            'x' => .{ 0b000, 0b101, 0b010, 0b101 },\n+            'y' => .{ 0b000, 0b101, 0b011, 0b110 },\n+            'z' => .{ 0b000, 0b111, 0b010, 0b111 },\n+            '0' => .{ 0b010, 0b101, 0b101, 0b010 },\n+            '1' => .{ 0b010, 0b110, 0b010, 0b111 },\n+            '2' => .{ 0b110, 0b001, 0b010, 0b111 },\n+            '3' => .{ 0b111, 0b011, 0b001, 0b110 },\n+            '4' => .{ 0b101, 0b111, 0b001, 0b001 },\n+            '5' => .{ 0b111, 0b110, 0b001, 0b110 },\n+            '6' => .{ 0b010, 0b100, 0b110, 0b010 },\n+            '7' => .{ 0b111, 0b001, 0b010, 0b010 },\n+            '8' => .{ 0b010, 0b111, 0b111, 0b010 },\n+            '9' => .{ 0b010, 0b011, 0b001, 0b010 },\n+            '!' => .{ 0b010, 0b010, 0b000, 0b010 },\n+            '?' => .{ 0b110, 0b011, 0b000, 0b010 },\n+            '.' => .{ 0b000, 0b000, 0b000, 0b010 },\n+            ',' => .{ 0b000, 0b000, 0b010, 0b100 },\n+            ':' => .{ 0b000, 0b010, 0b000, 0b010 },\n+            ';' => .{ 0b000, 0b010, 0b000, 0b100 },\n+            '-' => .{ 0b000, 0b000, 0b111, 0b000 },\n+            '+' => .{ 0b000, 0b010, 0b111, 0b010 },\n+            '=' => .{ 0b000, 0b111, 0b000, 0b111 },\n+            '*' => .{ 0b000, 0b101, 0b010, 0b101 },\n+            '/' => .{ 0b001, 0b001, 0b010, 0b100 },\n+            '\\\\' => .{ 0b100, 0b100, 0b010, 0b001 },\n+            '(' => .{ 0b010, 0b100, 0b100, 0b010 },\n+            ')' => .{ 0b010, 0b001, 0b001, 0b010 },\n+            '[' => .{ 0b110, 0b100, 0b100, 0b110 },\n+            ']' => .{ 0b011, 0b001, 0b001, 0b011 },\n+            '{' => .{ 0b011, 0b110, 0b110, 0b011 },\n+            '}' => .{ 0b110, 0b011, 0b011, 0b110 },\n+            '<' => .{ 0b001, 0b010, 0b100, 0b010 },\n+            '>' => .{ 0b100, 0b010, 0b001, 0b010 },\n+            '_' => .{ 0b000, 0b000, 0b000, 0b111 },\n+            '\"' => .{ 0b101, 0b101, 0b000, 0b000 },\n+            '\\'' => .{ 0b010, 0b010, 0b000, 0b000 },\n+            '&' => .{ 0b010, 0b101, 0b110, 0b011 },\n+            '#' => .{ 0b101, 0b111, 0b111, 0b101 },\n+            '$' => .{ 0b010, 0b111, 0b111, 0b010 },\n+            '%' => .{ 0b101, 0b001, 0b010, 0b101 },\n+            '@' => .{ 0b010, 0b111, 0b111, 0b010 },\n+            // Whitespace indicators\n+            1 => .{ 0b000, 0b010, 0b000, 0b000 }, // \u00b7 (middle dot for space)\n+            2 => .{ 0b100, 0b111, 0b001, 0b000 }, // \u2192 (arrow for tab)\n+            3 => .{ 0b001, 0b111, 0b100, 0b000 }, // \u21b5 (return for newline)\n+            4 => .{ 0b010, 0b111, 0b010, 0b000 }, // \u23ce (carriage return)\n+            else => .{ 0b111, 0b101, 0b101, 0b111 }, // Unknown char box\n+        };\n+    }\n+};"
    },
