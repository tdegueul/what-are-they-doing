00, 0b0100, 0b0010 },\n+            ')' => .{ 0b0100, 0b0010, 0b0001, 0b0001, 0b0010, 0b0100 },\n+            '[' => .{ 0b0110, 0b0100, 0b0100, 0b0100, 0b0100, 0b0110 },\n+            ']' => .{ 0b0110, 0b0010, 0b0010, 0b0010, 0b0010, 0b0110 },\n+            '{' => .{ 0b0010, 0b0100, 0b1000, 0b1000, 0b0100, 0b0010 },\n+            '}' => .{ 0b0100, 0b0010, 0b0001, 0b0001, 0b0010, 0b0100 },\n+            '<' => .{ 0b0010, 0b0100, 0b1000, 0b0100, 0b0010, 0b0001 },\n+            '>' => .{ 0b0100, 0b0010, 0b0001, 0b0010, 0b0100, 0b1000 },\n+            '_' => .{ 0b0000, 0b0000, 0b0000, 0b0000, 0b0000, 0b1111 },\n+            '\"' => .{ 0b1010, 0b1010, 0b0000, 0b0000, 0b0000, 0b0000 },\n+            '\\'' => .{ 0b0100, 0b0100, 0b0000, 0b0000, 0b0000, 0b0000 },\n+            '&' => .{ 0b0110, 0b1001, 0b0100, 0b1010, 0b1001, 0b0110 },\n+            '#' => .{ 0b1010, 0b1111, 0b1010, 0b1111, 0b1010, 0b0000 },\n+            '$' => .{ 0b0100, 0b0111, 0b1100, 0b0110, 0b1110, 0b0100 },\n+            '%' => .{ 0b1001, 0b0010, 0b0100, 0b1000, 0b1001, 0b0000 },\n+            '@' => .{ 0b0110, 0b1001, 0b1011, 0b1011, 0b1000, 0b0110 },\n+            // Whitespace indicators\n+            1 => .{ 0b0000, 0b0100, 0b0000, 0b0000, 0b0000, 0b0000 }, // \u00b7 (middle dot for space)\n+            2 => .{ 0b1000, 0b1100, 0b1111, 0b0001, 0b0001, 0b0000 }, // \u2192 (arrow for tab)\n+            3 => .{ 0b0001, 0b0011, 0b1111, 0b1000, 0b1000, 0b0000 }, // \u21b5 (return for newline)\n+            4 => .{ 0b0100, 0b1110, 0b0100, 0b0000, 0b1111, 0b0000 }, // \u23ce (carriage return)\n+            else => .{ 0b1111, 0b1001, 0b1001, 0b1001, 0b1001, 0b1111 }, // Unknown char box\n+        };\n+    }\n+};"
