      "blob_url": "https://github.com/tenzir/tenzir/blob/1c8ddbcfb0f19095c957dfd5dcea668ad92846e8/test-legacy%2Finputs%2Fpackage-roots%2Fudo-args%2Fargspkg%2Foperators%2Ftyped_named_secret.tql",
      "raw_url": "https://github.com/tenzir/tenzir/raw/1c8ddbcfb0f19095c957dfd5dcea668ad92846e8/test-legacy%2Finputs%2Fpackage-roots%2Fudo-args%2Fargspkg%2Foperators%2Ftyped_named_secret.tql",
      "contents_url": "https://api.github.com/repos/tenzir/tenzir/contents/test-legacy%2Finputs%2Fpackage-roots%2Fudo-args%2Fargspkg%2Foperators%2Ftyped_named_secret.tql?ref=1c8ddbcfb0f19095c957dfd5dcea668ad92846e8",
      "patch": "@@ -0,0 +1,10 @@\n+---\n+description: \"Accept a named argument that is declared as secret\"\n+args:\n+  named:\n+    - name: value\n+      type: secret\n+      description: \"Must be a secret expression\"\n+---\n+\n+assert_secret secret=$value, expected=\"const\""
