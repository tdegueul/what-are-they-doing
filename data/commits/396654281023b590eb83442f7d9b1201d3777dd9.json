      "additions": 18,
      "deletions": 6,
      "changes": 24,
      "blob_url": "https://github.com/philipp-spiess/walkingdevs.com/blob/396654281023b590eb83442f7d9b1201d3777dd9/src%2Fcomponents%2FAudioPlayer.astro",
