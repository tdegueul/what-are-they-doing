{
  "message": "test: migrate to vitest and run CI on bun/node\n\n\ud83d\udd2e View transcript: https://agentlogs.ai/s/nta4ildfkxppjzdn5lwelefz",
  "files": [
    {
      "sha": "b95422e6989b72c636f2405a86fa23880a98f5d6",
      "filename": ".github/workflows/ci.yml",
      "status": "modified",
      "additions": 38,
      "deletions": 14,
      "changes": 52,
      "blob_url": "https://github.com/philipp-spiess/openfuse/blob/1f57efc493b6d03370581607bfe714b652a86640/.github%2Fworkflows%2Fci.yml",
      "raw_url": "https://github.com/philipp-spiess/openfuse/raw/1f57efc493b6d03370581607bfe714b652a86640/.github%2Fworkflows%2Fci.yml",
      "contents_url": "https://api.github.com/repos/philipp-spiess/openfuse/contents/.github%2Fworkflows%2Fci.yml?ref=1f57efc493b6d03370581607bfe714b652a86640",
      "patch": "@@ -6,30 +6,54 @@ jobs:\n   test:\n     strategy:\n       matrix:\n-        include:\n-          - os: ubuntu-latest\n-            test-type: all\n-          - os: macos-latest\n-            test-type: unit\n+        os: [ubuntu-latest, macos-latest]\n+        runtime: [bun, node]\n \n     runs-on: ${{ matrix.os }}\n \n     steps:\n       - uses: actions/checkout@v4\n-      - uses: oven-sh/setup-bun@v2\n+\n+      - name: Setup Bun\n+        if: matrix.runtime == 'bun'\n+        uses: oven-sh/setup-bun@v2\n+\n+      - name: Setup Node\n+        if: matrix.runtime == 'node'\n+        uses: actions/setup-node@v4\n+        with:\n+          node-version: 22\n+\n+      - name: Install dependencies (Bun)\n+        if: matrix.runtime == 'bun'\n+        run: bun install\n+\n+      - name: Install dependencies (Node)\n+        if: matrix.runtime == 'node'\n+        run: npm install\n \n       - name: Install FUSE (Linux)\n         if: runner.os == 'Linux'\n         run: |\n           sudo apt-get update\n-          sudo apt-get install -y fuse3 libfuse3-dev\n-          sudo modprobe fuse\n+          sudo apt-get install -y libfuse-dev fuse3\n+\n+      - name: Install FUSE (macOS)\n+        if: runner.os == 'macOS'\n+        run: brew install macfuse\n+\n+      - name: Unit tests (Bun)\n+        if: matrix.runtime == 'bun'\n+        run: bunx vitest run\n \n-      - run: bun install\n+      - name: Unit tests (Node)\n+        if: matrix.runtime == 'node'\n+        run: npx vitest run\n \n-      - name: Unit tests\n-        run: bun test --filter core\n+      - name: Mount tests (Linux + Bun)\n+        if: runner.os == 'Linux' && matrix.runtime == 'bun'\n+        run: OPENFUSE_RUN_MOUNT_TESTS=1 bunx vitest run packages/openfuse/test/mount.test.ts\n \n-      - name: Integration tests (Linux only)\n-        if: matrix.test-type == 'all'\n-        run: bun test --filter mount\n+      - name: Mount tests (Linux + Node)\n+        if: runner.os == 'Linux' && matrix.runtime == 'node'\n+        run: OPENFUSE_RUN_MOUNT_TESTS=1 npx vitest run packages/openfuse/test/mount.test.ts"
    },
