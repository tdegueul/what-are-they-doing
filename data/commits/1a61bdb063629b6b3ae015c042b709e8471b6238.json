      "patch": "@@ -2034,16 +2034,17 @@\n                 <div class=\"sql-editor\">\n                     <div class=\"sql-editor-container\">\n                         <textarea class=\"sql-textarea\" id=\"sql-input\"\n-                            placeholder=\"SELECT * FROM read_lance('https://...') LIMIT 50\">-- \ud83d\ude80 Push-Down Filtering: Query 1M images, download only ~200KB (not 1.5GB!)\n-SELECT url, text, aesthetic FROM read_lance('https://data.metal0.dev/laion-1m/images.lance') \n-WHERE aesthetic > 0.7\n-NEAR 'sunset on the beach' \n+                            placeholder=\"SELECT * FROM read_lance('https://...') LIMIT 50\">-- \ud83d\ude80 Push-Down Filtering + JOIN (downloads ~200KB, not 1.5GB!)\n+SELECT i.url, i.text, t.text_zh, t.text_es\n+FROM read_lance('https://data.metal0.dev/laion-1m/images.lance') i\n+JOIN read_lance('https://data.metal0.dev/laion-1m/translations.lance') t ON i.rowid = t.row_id\n+WHERE i.embedding NEAR 'sunset'\n LIMIT 20</textarea>\n                         <div class=\"sql-highlight\" id=\"sql-highlight\" aria-hidden=\"true\"></div>\n                     </div>\n                     <div class=\"sql-examples\">\n                         <button class=\"sql-example\"\n-                            data-sql=\"SELECT url, text, aesthetic FROM read_lance('https://data.metal0.dev/laion-1m/images.lance') NEAR 'cat playing' LIMIT 20\"\n+                            data-sql=\"SELECT url, text, aesthetic FROM read_lance('https://data.metal0.dev/laion-1m/images.lance') WHERE embedding NEAR 'cat playing' LIMIT 20\"\n                             style=\"background: #7c3aed;\">\ud83d\udd2e NEAR 'cat'</button>\n                         <button class=\"sql-example\"\n                             data-sql=\"SELECT i.text, i.aesthetic, t.text_zh, t.text_es FROM read_lance('https://data.metal0.dev/laion-1m/images.lance') i JOIN translations t ON i.rowid = t.row_id LIMIT 20\"\n@@ -2789,10 +2790,11 @@ <h3>\n \n         // Default demo dataset URL - LAION 1M images dataset\n         const DEFAULT_DATASET_URL = 'https://data.metal0.dev/laion-1m/images.lance';\n-        const DEFAULT_QUERY = `-- \ud83d\ude80 Push-Down Filtering: Query 1M images, download only ~200KB (not 1.5GB!)\n-SELECT url, text, aesthetic FROM read_lance('https://data.metal0.dev/laion-1m/images.lance') \n-WHERE aesthetic > 0.7\n-NEAR 'sunset on the beach' \n+        const DEFAULT_QUERY = `-- \ud83d\ude80 Push-Down Filtering + JOIN (downloads ~200KB, not 1.5GB!)\n+SELECT i.url, i.text, t.text_zh, t.text_es\n+FROM read_lance('https://data.metal0.dev/laion-1m/images.lance') i\n+JOIN read_lance('https://data.metal0.dev/laion-1m/translations.lance') t ON i.rowid = t.row_id\n+WHERE i.embedding NEAR 'sunset'\n LIMIT 20`;\n \n         // Initialize"
