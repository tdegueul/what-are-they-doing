      "raw_url": "https://github.com/tenzir/claude-plugins/raw/954a4c0524bb6b4ff871f0d666138ea9afd08819/plugins%2Fdocs%2Fchangelog%2Freleases%2Fv2.0.0%2Fmanifest.yaml",
