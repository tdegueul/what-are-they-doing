{
  "message": "Fix MCP server startup error by using wrapper script\n\nThe plugin.json was pointing to cli/mcp-server (a bash script) which\nwas being run with 'node' command, causing a syntax error. Changed to\nuse cli/mcp-server-wrapper.js which is designed to work with node and\nproperly runs the bundled dist/mcp-server.js file.",
  "files": [
    {
      "sha": "dd4d10bc44d36a6e7c2c2b44d75236cf084a9d16",
      "filename": ".claude-plugin/plugin.json",
      "status": "modified",
      "additions": 1,
      "deletions": 1,
      "changes": 2,
      "blob_url": "https://github.com/obra/episodic-memory/blob/0df8a7ccb43655e79354d6ebdec9ac5d5b4cc7f4/.claude-plugin%2Fplugin.json",
      "raw_url": "https://github.com/obra/episodic-memory/raw/0df8a7ccb43655e79354d6ebdec9ac5d5b4cc7f4/.claude-plugin%2Fplugin.json",
      "contents_url": "https://api.github.com/repos/obra/episodic-memory/contents/.claude-plugin%2Fplugin.json?ref=0df8a7ccb43655e79354d6ebdec9ac5d5b4cc7f4",
      "patch": "@@ -14,7 +14,7 @@\n   \"mcpServers\": {\n     \"episodic-memory\": {\n       \"command\": \"node\",\n-      \"args\": [\"${CLAUDE_PLUGIN_ROOT}/cli/mcp-server\"],\n+      \"args\": [\"${CLAUDE_PLUGIN_ROOT}/cli/mcp-server-wrapper.js\"],\n       \"env\": {}\n     }\n   }"
    }
  ]
}
