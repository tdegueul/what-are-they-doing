      "blob_url": "https://github.com/tenzir/claude-plugins/blob/2f3fdc35a2ecc89aa7dc5c2f7a54ad2d9c348adc/plugins%2Fformatter%2Fchangelog%2Freleases%2Fv1.1.1%2Fnotes.md",
