      "contents_url": "https://api.github.com/repos/Dicklesworthstone/frankensqlite/contents/crates%2Ffsqlite-e2e%2FCargo.toml?ref=09f89b7ce7f4cce09d5b1cc158b6ff7c51086a05",
      "patch": "@@ -12,12 +12,25 @@ description = \"End-to-end differential testing and benchmark harness for Franken\n [lints]\n workspace = true\n \n+[features]\n+default = [\"linux-asupersync-uring\"]\n+linux-uring-fs = [\n+    \"fsqlite/linux-uring-fs\",\n+    \"fsqlite-core/linux-uring-fs\",\n+    \"fsqlite-vfs/linux-uring-fs\",\n+]\n+linux-asupersync-uring = [\n+    \"fsqlite/linux-asupersync-uring\",\n+    \"fsqlite-core/linux-asupersync-uring\",\n+    \"fsqlite-vfs/linux-asupersync-uring\",\n+]\n+\n [dependencies]\n-fsqlite = { workspace = true }\n-fsqlite-core = { workspace = true }\n+fsqlite = { path = \"../fsqlite\", version = \"0.1.1\", default-features = false, features = [\"json\", \"fts5\", \"rtree\"] }\n+fsqlite-core = { path = \"../fsqlite-core\", version = \"0.1.1\", default-features = false }\n fsqlite-error = { workspace = true }\n fsqlite-harness = { workspace = true }\n-fsqlite-vfs = { workspace = true }\n+fsqlite-vfs = { path = \"../fsqlite-vfs\", version = \"0.1.2\", default-features = false }\n fsqlite-types = { workspace = true }\n fsqlite-wal = { workspace = true }\n ftui = { workspace = true, features = [\"crossterm\"] }"
