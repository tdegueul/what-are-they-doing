{
  "message": "refactor: separate metal0-specific tests from CPython tests\n\n- Move simplified test files (*_simple.py) to tests/metal0_simple/\n- Keep tests/cpython/ pure with only original CPython test files\n- Add __new__ method handling to avoid self parameter shadowing",
  "files": [
    {
      "sha": "327c4ed101821413a1976eb2e6b06a32f95f0cb3",
      "filename": "src/codegen/native/statements/functions/generators/signature.zig",
      "status": "modified",
      "additions": 7,
      "deletions": 2,
      "changes": 9,
      "blob_url": "https://github.com/teamchong/metal0/blob/844879070847e3666a3c4a66acf7dfed4e8ff0f0/src%2Fcodegen%2Fnative%2Fstatements%2Ffunctions%2Fgenerators%2Fsignature.zig",
      "raw_url": "https://github.com/teamchong/metal0/raw/844879070847e3666a3c4a66acf7dfed4e8ff0f0/src%2Fcodegen%2Fnative%2Fstatements%2Ffunctions%2Fgenerators%2Fsignature.zig",
      "contents_url": "https://api.github.com/repos/teamchong/metal0/contents/src%2Fcodegen%2Fnative%2Fstatements%2Ffunctions%2Fgenerators%2Fsignature.zig?ref=844879070847e3666a3c4a66acf7dfed4e8ff0f0",
      "patch": "@@ -407,9 +407,14 @@ pub fn genMethodSignature(\n     // Check if self is actually used in the method body\n     const uses_self = self_analyzer.usesSelf(method.body);\n \n+    // For __new__ methods, the first Python parameter is 'cls' not 'self', and the body often\n+    // does 'self = super().__new__(cls)' which would shadow a 'self' parameter.\n+    // Use '_' to avoid shadowing.\n+    const is_new_method = std.mem.eql(u8, method.name, \"__new__\");\n+\n     // Use *const for methods that don't mutate self (read-only methods)\n-    // Use _ for self param if it's not actually used in the body\n-    const self_param_name = if (uses_self) \"self\" else \"_\";\n+    // Use _ for self param if it's not actually used in the body, or if it's __new__\n+    const self_param_name = if (is_new_method) \"_\" else if (uses_self) \"self\" else \"_\";\n \n     // Generate \"pub fn methodname(self_param: *[const] @This()\"\n     // Use @This() instead of class name to handle nested classes and forward references"
    },
