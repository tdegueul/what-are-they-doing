      "filename": "neovim/lua/plugins/mdx.lua",
      "status": "modified",
      "additions": 0,
      "deletions": 1,
      "changes": 1,
      "blob_url": "https://github.com/mavam/dotfiles/blob/c2d689fe2705c4057e5f2ba6a5a416772b3d6bd5/neovim%2Flua%2Fplugins%2Fmdx.lua",
      "raw_url": "https://github.com/mavam/dotfiles/raw/c2d689fe2705c4057e5f2ba6a5a416772b3d6bd5/neovim%2Flua%2Fplugins%2Fmdx.lua",
      "contents_url": "https://api.github.com/repos/mavam/dotfiles/contents/neovim%2Flua%2Fplugins%2Fmdx.lua?ref=c2d689fe2705c4057e5f2ba6a5a416772b3d6bd5",
      "patch": "@@ -1,6 +1,5 @@\n return {\n   'davidmh/mdx.nvim',\n-  config = true,\n   dependencies = {\n     'nvim-treesitter/nvim-treesitter'\n   }"
    }
  ]
