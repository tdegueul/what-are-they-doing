      "patch": "@@ -0,0 +1,24 @@\n+[package]\n+name = \"fcp-fuzz\"\n+version = \"0.0.0\"\n+publish = false\n+edition = \"2024\"\n+\n+[package.metadata]\n+cargo-fuzz = true\n+\n+[dependencies]\n+libfuzzer-sys = \"0.4\"\n+\n+fcp-protocol = { path = \"../crates/fcp-protocol\" }\n+fcp-crypto = { path = \"../crates/fcp-crypto\" }\n+\n+[[bin]]\n+name = \"fuzz_capability\"\n+path = \"fuzz_targets/capability.rs\"\n+test = false\n+doc = false\n+bench = false\n+\n+[workspace]\n+members = [\".\"]"
