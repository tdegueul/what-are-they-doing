      "patch": "@@ -0,0 +1,14 @@\n+{\n+\t\"name\": \"brave-search\",\n+\t\"version\": \"1.0.0\",\n+\t\"type\": \"module\",\n+\t\"description\": \"Headless web search via Brave Search - no browser required\",\n+\t\"author\": \"Mario Zechner\",\n+\t\"license\": \"MIT\",\n+\t\"dependencies\": {\n+\t\t\"@mozilla/readability\": \"^0.6.0\",\n+\t\t\"jsdom\": \"^27.0.1\",\n+\t\t\"turndown\": \"^7.2.2\",\n+\t\t\"turndown-plugin-gfm\": \"^1.0.2\"\n+\t}\n+}"
