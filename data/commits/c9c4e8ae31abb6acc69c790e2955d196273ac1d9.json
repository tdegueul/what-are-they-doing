      "deletions": 17,
      "changes": 17,
      "blob_url": "https://github.com/obra/episodic-memory/blob/024b0dfb3248231d5545a2dccc185edb44e14f85/cli%2Fensure-dependencies",
      "raw_url": "https://github.com/obra/episodic-memory/raw/024b0dfb3248231d5545a2dccc185edb44e14f85/cli%2Fensure-dependencies",
      "contents_url": "https://api.github.com/repos/obra/episodic-memory/contents/cli%2Fensure-dependencies?ref=024b0dfb3248231d5545a2dccc185edb44e14f85",
      "patch": "@@ -1,17 +0,0 @@\n-#!/bin/bash\n-# Ensure plugin dependencies are installed\n-# This runs on SessionStart to handle plugin installation\n-\n-PLUGIN_ROOT=\"${CLAUDE_PLUGIN_ROOT}\"\n-\n-# If CLAUDE_PLUGIN_ROOT is not set, exit silently\n-if [ -z \"$PLUGIN_ROOT\" ]; then\n-  exit 0\n-fi\n-\n-# Check if node_modules exists\n-if [ ! -d \"$PLUGIN_ROOT/node_modules\" ]; then\n-  echo \"Installing episodic-memory dependencies...\" >&2\n-  cd \"$PLUGIN_ROOT\" && npm install --quiet 2>&1 | grep -v \"^npm WARN\"\n-  echo \"Dependencies installed.\" >&2\n-fi"
    },
    {
      "sha": "f47cd13bd296721a4263cd734bfb5349e207be6b",
      "filename": "cli/mcp-server-wrapper",
      "status": "added",
      "additions": 27,
      "deletions": 0,
      "changes": 27,
      "blob_url": "https://github.com/obra/episodic-memory/blob/c9c4e8ae31abb6acc69c790e2955d196273ac1d9/cli%2Fmcp-server-wrapper",
      "raw_url": "https://github.com/obra/episodic-memory/raw/c9c4e8ae31abb6acc69c790e2955d196273ac1d9/cli%2Fmcp-server-wrapper",
      "contents_url": "https://api.github.com/repos/obra/episodic-memory/contents/cli%2Fmcp-server-wrapper?ref=c9c4e8ae31abb6acc69c790e2955d196273ac1d9",
      "patch": "@@ -0,0 +1,27 @@\n+#!/bin/bash\n+# Wrapper script for MCP server that ensures dependencies are installed\n+# This runs before the MCP server starts\n+\n+# Determine plugin root directory\n+if [ -n \"$CLAUDE_PLUGIN_ROOT\" ]; then\n+  PLUGIN_ROOT=\"$CLAUDE_PLUGIN_ROOT\"\n+else\n+  # Fall back to script directory\n+  SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n+  PLUGIN_ROOT=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n+fi\n+\n+# Check if node_modules exists\n+if [ ! -d \"$PLUGIN_ROOT/node_modules\" ]; then\n+  echo \"Installing episodic-memory dependencies (first run only)...\" >&2\n+  (cd \"$PLUGIN_ROOT\" && npm install --loglevel=error) >&2\n+  if [ $? -eq 0 ]; then\n+    echo \"Dependencies installed successfully.\" >&2\n+  else\n+    echo \"ERROR: Failed to install dependencies. Please run: cd \\\"$PLUGIN_ROOT\\\" && npm install\" >&2\n+    exit 1\n+  fi\n+fi\n+\n+# Start the MCP server\n+exec node \"$PLUGIN_ROOT/dist/mcp-server.js\""
    },
