      "patch": "@@ -0,0 +1,96 @@\n+<!DOCTYPE html>\n+<html lang=\"en\">\n+<head>\n+    <meta charset=\"UTF-8\">\n+    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n+    <title>Settings - Stockyard</title>\n+    <script src=\"/static/js/htmx.min.js\"></script>\n+    <script defer src=\"/static/js/alpine.min.js\"></script>\n+    <script src=\"/static/js/tailwind.min.js\"></script>\n+    <style>\n+        [x-cloak] { display: none !important; }\n+    </style>\n+</head>\n+<body class=\"bg-gray-50 text-gray-900 h-screen flex flex-col\">\n+    <!-- Header -->\n+    <header class=\"bg-white border-b border-gray-200 px-4 py-3 flex items-center justify-between shrink-0\">\n+        <div class=\"flex items-center gap-4\">\n+            <a href=\"/\" class=\"font-semibold text-lg hover:text-blue-600\">Stockyard</a>\n+            <span class=\"text-gray-400\">/</span>\n+            <span class=\"text-gray-600\">Settings</span>\n+        </div>\n+        <div class=\"flex items-center gap-4\">\n+            {{if .UserAvatar}}\n+            <img src=\"{{.UserAvatar}}\" alt=\"{{.User}}\" class=\"w-8 h-8 rounded-full\">\n+            {{else}}\n+            <div class=\"w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center text-white text-sm font-bold uppercase\">\n+                {{if .User}}{{slice .User 0 1}}{{else}}?{{end}}\n+            </div>\n+            {{end}}\n+            <span class=\"text-sm text-gray-600 hidden sm:inline\">{{.User}}</span>\n+        </div>\n+    </header>\n+\n+    <!-- Main content -->\n+    <main class=\"flex-1 overflow-auto p-6\">\n+        <div class=\"max-w-2xl mx-auto\">\n+            <div class=\"bg-white rounded-lg shadow border border-gray-200\">\n+                <div class=\"p-4 border-b border-gray-200\">\n+                    <h1 class=\"text-xl font-semibold text-gray-900\">Settings</h1>\n+                </div>\n+\n+                <div class=\"p-6 space-y-6\">\n+                    <!-- Instance Info -->\n+                    <div>\n+                        <h2 class=\"text-sm font-medium text-gray-900 mb-3\">Instance Information</h2>\n+                        <dl class=\"grid grid-cols-2 gap-4 text-sm\">\n+                            <div>\n+                                <dt class=\"text-gray-500\">Instance ID</dt>\n+                                <dd class=\"font-mono text-gray-900\">{{.InstanceID}}</dd>\n+                            </div>\n+                            <div>\n+                                <dt class=\"text-gray-500\">Version</dt>\n+                                <dd class=\"font-mono text-gray-900\">{{.Version}}</dd>\n+                            </div>\n+                        </dl>\n+                    </div>\n+\n+                    <hr class=\"border-gray-200\">\n+\n+                    <!-- ZFS Config -->\n+                    <div>\n+                        <h2 class=\"text-sm font-medium text-gray-900 mb-3\">Storage (ZFS)</h2>\n+                        <dl class=\"grid grid-cols-2 gap-4 text-sm\">\n+                            <div>\n+                                <dt class=\"text-gray-500\">Pool</dt>\n+                                <dd class=\"font-mono text-gray-900\">{{.ZFSPool}}</dd>\n+                            </div>\n+                            <div>\n+                                <dt class=\"text-gray-500\">VMs Path</dt>\n+                                <dd class=\"font-mono text-gray-900\">{{.ZFSVMsPath}}</dd>\n+                            </div>\n+                        </dl>\n+                    </div>\n+\n+                    <hr class=\"border-gray-200\">\n+\n+                    <!-- Network Config -->\n+                    <div>\n+                        <h2 class=\"text-sm font-medium text-gray-900 mb-3\">Network</h2>\n+                        <dl class=\"grid grid-cols-2 gap-4 text-sm\">\n+                            <div>\n+                                <dt class=\"text-gray-500\">Bridge</dt>\n+                                <dd class=\"font-mono text-gray-900\">{{.BridgeName}}</dd>\n+                            </div>\n+                            <div>\n+                                <dt class=\"text-gray-500\">VM Subnet</dt>\n+                                <dd class=\"font-mono text-gray-900\">{{.VMSubnet}}</dd>\n+                            </div>\n+                        </dl>\n+                    </div>\n+                </div>\n+            </div>\n+        </div>\n+    </main>\n+</body>\n+</html>"
    }
  ]
