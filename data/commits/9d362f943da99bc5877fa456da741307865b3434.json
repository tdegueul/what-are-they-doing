{
  "message": "feat(dashboard): add activity and settings page templates\n\nAdd placeholder templates for:\n- Activity page: will show VM events and logs\n- Settings page: will show daemon configuration\n\nThese templates follow the same structure as fleet.html with consistent\nheader and navigation.\n\n\ud83e\udd16 Generated with [Claude Code](https://claude.com/claude-code)\n\nCo-Authored-By: Claude Opus 4.5 <noreply@anthropic.com>",
  "files": [
    {
      "sha": "c7b88528bae8127c83fdfa882480a4ccb07d697d",
      "filename": "pkg/dashboard/templates/activity.html",
      "status": "added",
      "additions": 90,
      "deletions": 0,
      "changes": 90,
      "blob_url": "https://github.com/prime-radiant-inc/stockyard/blob/9d362f943da99bc5877fa456da741307865b3434/pkg%2Fdashboard%2Ftemplates%2Factivity.html",
      "raw_url": "https://github.com/prime-radiant-inc/stockyard/raw/9d362f943da99bc5877fa456da741307865b3434/pkg%2Fdashboard%2Ftemplates%2Factivity.html",
      "contents_url": "https://api.github.com/repos/prime-radiant-inc/stockyard/contents/pkg%2Fdashboard%2Ftemplates%2Factivity.html?ref=9d362f943da99bc5877fa456da741307865b3434",
      "patch": "@@ -0,0 +1,90 @@\n+<!DOCTYPE html>\n+<html lang=\"en\">\n+<head>\n+    <meta charset=\"UTF-8\">\n+    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n+    <title>Activity - Stockyard</title>\n+    <script src=\"/static/js/htmx.min.js\"></script>\n+    <script defer src=\"/static/js/alpine.min.js\"></script>\n+    <script src=\"/static/js/tailwind.min.js\"></script>\n+    <style>\n+        [x-cloak] { display: none !important; }\n+    </style>\n+</head>\n+<body class=\"bg-gray-50 text-gray-900 h-screen flex flex-col\">\n+    <!-- Header -->\n+    <header class=\"bg-white border-b border-gray-200 px-4 py-3 flex items-center justify-between shrink-0\">\n+        <div class=\"flex items-center gap-4\">\n+            <a href=\"/\" class=\"font-semibold text-lg hover:text-blue-600\">Stockyard</a>\n+            <span class=\"text-gray-400\">/</span>\n+            <span class=\"text-gray-600\">Activity</span>\n+        </div>\n+        <div class=\"flex items-center gap-4\">\n+            {{if .UserAvatar}}\n+            <img src=\"{{.UserAvatar}}\" alt=\"{{.User}}\" class=\"w-8 h-8 rounded-full\">\n+            {{else}}\n+            <div class=\"w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center text-white text-sm font-bold uppercase\">\n+                {{if .User}}{{slice .User 0 1}}{{else}}?{{end}}\n+            </div>\n+            {{end}}\n+            <span class=\"text-sm text-gray-600 hidden sm:inline\">{{.User}}</span>\n+        </div>\n+    </header>\n+\n+    <!-- Main content -->\n+    <main class=\"flex-1 overflow-auto p-6\">\n+        <div class=\"max-w-4xl mx-auto\">\n+            <div class=\"bg-white rounded-lg shadow border border-gray-200\" x-data=\"{ filter: 'all' }\">\n+                <div class=\"flex items-center justify-between p-4 border-b border-gray-200\">\n+                    <h1 class=\"text-xl font-semibold text-gray-900\">Activity</h1>\n+                    <!-- Filter buttons -->\n+                    <div class=\"flex gap-2\">\n+                        <button @click=\"filter = 'all'\" :class=\"filter === 'all' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-600'\" class=\"px-3 py-1 text-sm rounded\">All</button>\n+                        <button @click=\"filter = 'started'\" :class=\"filter === 'started' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600'\" class=\"px-3 py-1 text-sm rounded\">Started</button>\n+                        <button @click=\"filter = 'stopped'\" :class=\"filter === 'stopped' ? 'bg-gray-200 text-gray-700' : 'bg-gray-100 text-gray-600'\" class=\"px-3 py-1 text-sm rounded\">Stopped</button>\n+                        <button @click=\"filter = 'failed'\" :class=\"filter === 'failed' ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-600'\" class=\"px-3 py-1 text-sm rounded\">Failed</button>\n+                    </div>\n+                </div>\n+\n+                <!-- Event list -->\n+                <div class=\"divide-y divide-gray-100\">\n+                    {{range .Events}}\n+                    <div class=\"px-4 py-3 hover:bg-gray-50\"\n+                         x-show=\"filter === 'all' || (filter === 'started' && '{{.Type}}' === 'vm_started') || (filter === 'stopped' && '{{.Type}}' === 'vm_stopped') || (filter === 'failed' && '{{.Type}}' === 'vm_failed')\">\n+                        <div class=\"flex items-start gap-3\">\n+                            {{if eq .Type \"vm_started\"}}\n+                            <span class=\"w-2 h-2 mt-2 bg-green-500 rounded-full flex-shrink-0\"></span>\n+                            {{else if eq .Type \"vm_stopped\"}}\n+                            <span class=\"w-2 h-2 mt-2 bg-gray-400 rounded-full flex-shrink-0\"></span>\n+                            {{else if eq .Type \"vm_failed\"}}\n+                            <span class=\"w-2 h-2 mt-2 bg-red-500 rounded-full flex-shrink-0\"></span>\n+                            {{else}}\n+                            <span class=\"w-2 h-2 mt-2 bg-blue-500 rounded-full flex-shrink-0\"></span>\n+                            {{end}}\n+                            <div class=\"flex-1 min-w-0\">\n+                                <div class=\"flex items-center justify-between\">\n+                                    <a href=\"/vm/{{.TaskID}}\" class=\"font-medium text-gray-900 hover:text-blue-600 truncate\">{{.TaskID}}</a>\n+                                    <span class=\"text-xs text-gray-400 flex-shrink-0 ml-2\">{{.Timestamp.Format \"Jan 2 15:04\"}}</span>\n+                                </div>\n+                                <p class=\"text-sm text-gray-600\">{{.Message}}</p>\n+                                {{if .RepoURL}}\n+                                <p class=\"text-xs text-gray-400 truncate\">{{.RepoURL}}</p>\n+                                {{end}}\n+                            </div>\n+                        </div>\n+                    </div>\n+                    {{else}}\n+                    <div class=\"p-8 text-center text-gray-500\">\n+                        <svg class=\"w-12 h-12 mx-auto mb-4 text-gray-300\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z\"/>\n+                        </svg>\n+                        <p>No activity yet</p>\n+                        <p class=\"text-sm mt-1\">VM lifecycle events will appear here</p>\n+                    </div>\n+                    {{end}}\n+                </div>\n+            </div>\n+        </div>\n+    </main>\n+</body>\n+</html>"
    },
