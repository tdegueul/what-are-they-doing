      "deletions": 0,
      "changes": 9,
      "blob_url": "https://github.com/tenzir/tree-sitter-tql/blob/b18eba223448a89f20c07eb6065e099263d76ca5/changelog%2Freleases%2Fv1.0.0%2Fnotes.md",
