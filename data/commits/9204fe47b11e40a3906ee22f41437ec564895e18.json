      "patch": "@@ -8,6 +8,10 @@\n     <script defer src=\"https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js\"></script>\n     <script src=\"https://cdn.tailwindcss.com\"></script>\n     <script src=\"https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js\"></script>\n+    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/xterm@5.3.0/css/xterm.css\">\n+    <script src=\"https://cdn.jsdelivr.net/npm/xterm@5.3.0/lib/xterm.min.js\"></script>\n+    <script src=\"https://cdn.jsdelivr.net/npm/xterm-addon-fit@0.8.0/lib/xterm-addon-fit.min.js\"></script>\n+    <script src=\"https://cdn.jsdelivr.net/npm/xterm-addon-web-links@0.9.0/lib/xterm-addon-web-links.min.js\"></script>\n     <style>\n         [x-cloak] { display: none !important; }\n     </style>\n@@ -438,6 +442,36 @@ <h2 class=\"text-lg font-medium\">Logs</h2>\n                     </div>\n                 </div>\n \n+                <!-- Terminal Panel -->\n+                <div class=\"bg-white rounded-lg shadow border border-gray-200\"\n+                     x-data=\"{ showTerminal: false, connected: false, connecting: false }\">\n+                    <div class=\"px-4 py-3 border-b border-gray-200 flex items-center justify-between\">\n+                        <h2 class=\"text-lg font-medium\">Terminal</h2>\n+                        <div class=\"flex items-center gap-2\">\n+                            <span x-show=\"connected\" class=\"text-xs text-green-600 flex items-center gap-1\">\n+                                <span class=\"w-2 h-2 bg-green-500 rounded-full\"></span>\n+                                Connected\n+                            </span>\n+                            <span x-show=\"connecting\" class=\"text-xs text-yellow-600\">Connecting...</span>\n+                            <button @click=\"showTerminal = !showTerminal\"\n+                                    class=\"text-xs text-blue-600 hover:underline\"\n+                                    x-text=\"showTerminal ? 'Hide' : 'Open Terminal'\">\n+                            </button>\n+                        </div>\n+                    </div>\n+                    <div class=\"p-4\">\n+                        <div x-show=\"showTerminal\" x-transition class=\"rounded overflow-hidden\">\n+                            <div id=\"terminal-container\" class=\"h-80 bg-black\"></div>\n+                        </div>\n+                        <div x-show=\"!showTerminal\" class=\"text-center py-6\">\n+                            <svg class=\"mx-auto h-10 w-10 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z\"/>\n+                            </svg>\n+                            <p class=\"mt-2 text-sm text-gray-500\">Click \"Open Terminal\" to connect</p>\n+                        </div>\n+                    </div>\n+                </div>\n+\n                 <!-- Details Panel -->\n                 <div class=\"bg-white rounded-lg shadow border border-gray-200\">\n                     <div class=\"px-4 py-3 border-b border-gray-200\">"
