      "raw_url": "https://github.com/Dicklesworthstone/fast_cmaes/raw/ead491fec0b105ebed865ae9732bb47940a02ff3/rust-toolchain.toml",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/fast_cmaes/contents/rust-toolchain.toml?ref=ead491fec0b105ebed865ae9732bb47940a02ff3",
