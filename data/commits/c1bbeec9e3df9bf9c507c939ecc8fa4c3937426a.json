      "patch": "@@ -0,0 +1,9 @@\n+from codex_subagent.paths import Paths\n+\n+\n+def test_paths_create_directories(tmp_path):\n+    base = tmp_path / \".codex-subagent\"\n+    paths = Paths(base)\n+    paths.ensure()\n+    assert (base / \"state\").is_dir()\n+    assert (base / \"logs\").is_dir()"
