hitespace-nowrap text-sm\" x-data=\"{ actionsOpen: false }\" @click.stop>\n+                                        <div class=\"relative\">\n+                                            <button @click=\"actionsOpen = !actionsOpen\" @click.outside=\"actionsOpen = false\" class=\"text-gray-500 hover:text-gray-700\">\n+                                                <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                                                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z\"/>\n+                                                </svg>\n+                                            </button>\n+                                            <div x-show=\"actionsOpen\" x-cloak class=\"absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg border border-gray-200 z-10\">\n+                                                <div class=\"py-1\">\n+                                                    <button @click=\"copySSH('{{.TailscaleHost}}')\" class=\"block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100\">Copy SSH Command</button>\n+                                                    <button hx-post=\"/api/vm/{{.ID}}/stop\" hx-swap=\"none\" class=\"block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100\">Stop</button>\n+                                                    <button hx-delete=\"/api/vm/{{.ID}}\" hx-swap=\"none\" hx-confirm=\"Are you sure you want to destroy this VM?\" class=\"block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-100\">Destroy</button>\n+                                                </div>\n+                                            </div>\n+                                        </div>\n+                                    </td>\n+                                </tr>\n+