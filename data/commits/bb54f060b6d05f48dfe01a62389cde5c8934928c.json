{
  "message": "fix(ci): use chained Path::join for Windows-native separators in ext_conformance\n\nOn Windows, `cwd.join(\"dir/sub/file.rs\")` produces mixed separators\n(`\\dir/sub/file.rs`). Use chained `.join(\"dir\").join(\"sub\").join(\"file.rs\")`\nso each segment gets native separators consistently.\n\nCo-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>",
  "files": [
    {
      "sha": "69996856dec179e3922b4105bdf1dc37f431259d",
      "filename": "tests/ext_conformance.rs",
      "status": "modified",
      "additions": 1,
      "deletions": 1,
      "changes": 2,
      "blob_url": "https://github.com/Dicklesworthstone/pi_agent_rust/blob/bb54f060b6d05f48dfe01a62389cde5c8934928c/tests%2Fext_conformance.rs",
      "raw_url": "https://github.com/Dicklesworthstone/pi_agent_rust/raw/bb54f060b6d05f48dfe01a62389cde5c8934928c/tests%2Fext_conformance.rs",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/pi_agent_rust/contents/tests%2Fext_conformance.rs?ref=bb54f060b6d05f48dfe01a62389cde5c8934928c",
      "patch": "@@ -184,7 +184,7 @@ fn normalizes_dynamic_fields_paths_and_ansi() {\n         },\n         \"source\": { \"component\": \"runtime\", \"host\": \"host.name\", \"pid\": 4242 },\n         \"data\": {\n-            \"path\": cwd.join(\"dir/sub/file.rs\").display().to_string(),\n+            \"path\": cwd.join(\"dir\").join(\"sub\").join(\"file.rs\").display().to_string(),\n             \"note\": \"\\u{1b}[1mBold\\u{1b}[0m\"\n         }\n     });"
    }
  ]
