      "patch": "@@ -1,25 +0,0 @@\n-: \"${BATS_TEST_TIMEOUT:=60}\"\n-\n-setup() {\n-  bats_load_library bats-support\n-  bats_load_library bats-assert\n-  bats_load_library bats-tenzir\n-}\n-\n-@test \"parse a single message\" {\n-  # This is technically not valid GELF, but we read it nonetheless.\n-  jq -cn '{x: 1, y: \"foo\", z: 4.2}' | check tenzir \"read_gelf\"\n-}\n-\n-@test \"parse multiple messages\" {\n-  # This test ensures that we correctly identify the NULL byte as separator.\n-  jq -cn '{x: 1}, {x: 2}, {x: 3}' | tr '\\n' '\\0' | check tenzir \"read_gelf\"\n-}\n-\n-@test \"unflatten underscores\" {\n-  check tenzir 'shell \"jq -cn \\\"{x_y_z: 1}\\\"\" | read_json | this = this.unflatten(\"_\")'\n-  check tenzir 'shell \"jq -cn \\\"{_x_y_z: 1}\\\"\" | read_json | this = this.unflatten(\"_\")'\n-  check tenzir 'shell \"jq -cn \\\"{x_y_z_: 1}\\\"\" | read_json | this = this.unflatten(\"_\")'\n-  check tenzir 'shell \"jq -cn \\\"{_x_y_z_: 1}\\\"\" | read_json | this = this.unflatten(\"_\")'\n-  check tenzir 'shell \"jq -cn \\\"{x__y_z: 1}\\\"\" | read_json | this = this.unflatten(\"_\")'\n-}"
