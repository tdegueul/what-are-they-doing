      "filename": "crates/wa-core/src/patterns.rs",
      "status": "modified",
      "additions": 1,
      "deletions": 1,
      "changes": 2,
      "blob_url": "https://github.com/Dicklesworthstone/frankenterm/blob/c1fb75410763261e70383a515021d9366f2044e5/crates%2Fwa-core%2Fsrc%2Fpatterns.rs",
      "raw_url": "https://github.com/Dicklesworthstone/frankenterm/raw/c1fb75410763261e70383a515021d9366f2044e5/crates%2Fwa-core%2Fsrc%2Fpatterns.rs",
