      "raw_url": "https://github.com/tenzir/test/raw/3758aa8f1aab8fd247a2c1aa6af775c7806f490a/pyproject.toml",
      "contents_url": "https://api.github.com/repos/tenzir/test/contents/pyproject.toml?ref=3758aa8f1aab8fd247a2c1aa6af775c7806f490a",
      "patch": "@@ -45,7 +45,7 @@ packages = [\"src/tenzir_test\"]\n include = [\n   \"/src/**/*\",\n   \"/tests\",\n-  \"/example\",\n+  \"/example-project\",\n   \"/scripts\",\n   \"/README.md\",\n   \"/CONTRIBUTING.md\","
