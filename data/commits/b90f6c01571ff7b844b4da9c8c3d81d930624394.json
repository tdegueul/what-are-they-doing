    {
      "sha": "835e6adf83f2156dcdc62c9426481f9b11f1ee44",
      "filename": "Moltipass/Package.swift",
      "status": "added",
      "additions": 37,
      "deletions": 0,
      "changes": 37,
      "blob_url": "https://github.com/obra/moltipass/blob/b90f6c01571ff7b844b4da9c8c3d81d930624394/Moltipass%2FPackage.swift",
      "raw_url": "https://github.com/obra/moltipass/raw/b90f6c01571ff7b844b4da9c8c3d81d930624394/Moltipass%2FPackage.swift",
      "contents_url": "https://api.github.com/repos/obra/moltipass/contents/Moltipass%2FPackage.swift?ref=b90f6c01571ff7b844b4da9c8c3d81d930624394",
      "patch": "@@ -0,0 +1,37 @@\n+// swift-tools-version: 6.0\n+\n+import PackageDescription\n+\n+let package = Package(\n+    name: \"Moltipass\",\n+    platforms: [\n+        .iOS(.v17),\n+        .macOS(.v14),\n+    ],\n+    products: [\n+        // An xtool project should contain exactly one library product,\n+        // representing the main app.\n+        .library(\n+            name: \"Moltipass\",\n+            targets: [\"Moltipass\", \"MoltipassApp\"]\n+        ),\n+    ],\n+    targets: [\n+        // Library code (testable)\n+        .target(\n+            name: \"Moltipass\",\n+            path: \"Sources/Moltipass\"\n+        ),\n+        // App entry point (not testable)\n+        .target(\n+            name: \"MoltipassApp\",\n+            dependencies: [\"Moltipass\"],\n+            path: \"Sources/MoltipassApp\"\n+        ),\n+        .testTarget(\n+            name: \"MoltipassTests\",\n+            dependencies: [\"Moltipass\"],\n+            path: \"Tests/MoltipassTests\"\n+        ),\n+    ]\n+)"
    },
