      "contents_url": "https://api.github.com/repos/prime-radiant-inc/stockyard/contents/pkg%2Fdashboard%2Ftemplates%2Ferror.html?ref=21416ecacd3d80e256cb8cb4f72afd7c9d7cd158",
      "patch": "@@ -0,0 +1,56 @@\n+<!DOCTYPE html>\n+<html lang=\"en\">\n+<head>\n+    <meta charset=\"UTF-8\">\n+    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n+    <title>{{.Code}} - Stockyard</title>\n+    <script src=\"/static/js/htmx.min.js\"></script>\n+    <script defer src=\"/static/js/alpine.min.js\"></script>\n+    <script src=\"/static/js/tailwind.min.js\"></script>\n+    <style>\n+        [x-cloak] { display: none !important; }\n+    </style>\n+</head>\n+<body class=\"bg-gray-50 text-gray-900 h-screen flex flex-col\">\n+    <!-- Top bar -->\n+    <header class=\"bg-white border-b border-gray-200 px-4 py-2 flex items-center justify-between\">\n+        <div class=\"flex items-center gap-4\">\n+            <span class=\"font-semibold text-lg\">Stockyard</span>\n+        </div>\n+        <div class=\"flex items-center gap-2\">\n+            {{if .UserAvatar}}\n+            <img src=\"{{.UserAvatar}}\" alt=\"{{.User}}\" class=\"w-8 h-8 rounded-full\">\n+            {{else}}\n+            <div class=\"w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center text-white text-sm font-bold uppercase\">\n+                {{if .User}}{{slice .User 0 1}}{{else}}?{{end}}\n+            </div>\n+            {{end}}\n+            <span class=\"text-sm text-gray-600 hidden sm:inline\">{{.User}}</span>\n+        </div>\n+    </header>\n+\n+    <div class=\"flex flex-1 overflow-hidden\">\n+        <!-- Sidebar -->\n+        {{template \"sidebar\" .}}\n+\n+        <!-- Main content -->\n+        <main class=\"flex-1 overflow-auto p-6\">\n+            <div class=\"max-w-lg mx-auto mt-16\">\n+                <div class=\"text-center\">\n+                    <h1 class=\"text-6xl font-bold text-gray-300\">{{.Code}}</h1>\n+                    <h2 class=\"mt-4 text-2xl font-semibold text-gray-900\">{{.Title}}</h2>\n+                    <p class=\"mt-2 text-gray-600\">{{.Message}}</p>\n+                    <div class=\"mt-8\">\n+                        <a href=\"/\" class=\"inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700\">\n+                            <svg class=\"w-4 h-4 mr-2\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M10 19l-7-7m0 0l7-7m-7 7h18\"/>\n+                            </svg>\n+                            Back to Fleet\n+                        </a>\n+                    </div>\n+                </div>\n+            </div>\n+        </main>\n+    </div>\n+</body>\n+</html>"
    }
