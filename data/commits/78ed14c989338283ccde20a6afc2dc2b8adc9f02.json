      "patch": "@@ -0,0 +1,5 @@\n+// Multi-row merge: exercises columnar if_else with mixed null/non-null parents.\n+from {a: {x: 1, y: 2}, b: {x: 10, z: 3}},\n+  {a: {x: 1, y: 2}, b: null},\n+  {a: null, b: {x: 10, z: 3}}\n+this = merge(a, b)"
