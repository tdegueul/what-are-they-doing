      "patch": "@@ -0,0 +1,37 @@\n+# OS cruft\n+.DS_Store\n+Thumbs.db\n+\n+# Editors\n+.idea/\n+.vscode/\n+*.swp\n+*.swo\n+\n+# Environment secrets\n+.env\n+.env.local\n+.env.*.local\n+\n+# Dependencies\n+node_modules/\n+\n+# Bun / TypeScript\n+*.tsbuildinfo\n+\n+# Build artifacts\n+dist/\n+\n+# Logs and temp files\n+*.log\n+npm-debug.log*\n+yarn-debug.log*\n+yarn-error.log*\n+pnpm-debug.log*\n+*.tmp\n+\n+# Playwright outputs\n+playwright-report/\n+test-results/\n+.playwright/\n+"
