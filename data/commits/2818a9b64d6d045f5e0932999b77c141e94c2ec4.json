      "patch": "@@ -0,0 +1,26 @@\n+{\n+  \"name\": \"chatgpt-shared-conversation-to-markdown-file\",\n+  \"version\": \"0.1.0\",\n+  \"description\": \"CLI to download a ChatGPT share link and save it as clean Markdown.\",\n+  \"license\": \"MIT\",\n+  \"bin\": {\n+    \"csctm\": \"./dist/csctm\"\n+  },\n+  \"type\": \"module\",\n+  \"scripts\": {\n+    \"build\": \"bun build src/index.ts --compile --outfile dist/csctm --external electron --external chromium-bidi/lib/cjs/bidiMapper/BidiMapper --external chromium-bidi/lib/cjs/cdp/CdpConnection\",\n+    \"dev\": \"bun run src/index.ts\"\n+  },\n+  \"dependencies\": {\n+    \"chalk\": \"^5.3.0\",\n+    \"playwright-chromium\": \"^1.46.1\",\n+    \"turndown\": \"^7.2.0\"\n+  },\n+  \"devDependencies\": {\n+    \"@types/node\": \"^24.10.1\",\n+    \"@types/turndown\": \"^5.0.6\",\n+    \"eslint\": \"^9.39.1\",\n+    \"typescript\": \"^5.9.3\",\n+    \"typescript-eslint\": \"^8.48.1\"\n+  }\n+}"
