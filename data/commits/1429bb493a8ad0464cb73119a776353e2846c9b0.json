{
  "message": "refactor: move prebuilt/ out of vendor/\n\nMove prebuilt libraries to top-level prebuilt/ folder to separate\nthem from vendor submodules. This makes git status cleaner since\nvendor/ only contains submodules now.\n\nUpdated references in:\n- build.zig\n- .gitignore\n- scripts/build-wamr.sh",
  "files": [
    {
      "sha": "a14e3452e08589eb51cc65949e99d6df10d63aa7",
      "filename": ".gitignore",
      "status": "modified",
      "additions": 4,
      "deletions": 4,
      "changes": 8,
      "blob_url": "https://github.com/teamchong/edgebox/blob/1429bb493a8ad0464cb73119a776353e2846c9b0/.gitignore",
      "raw_url": "https://github.com/teamchong/edgebox/raw/1429bb493a8ad0464cb73119a776353e2846c9b0/.gitignore",
      "contents_url": "https://api.github.com/repos/teamchong/edgebox/contents/.gitignore?ref=1429bb493a8ad0464cb73119a776353e2846c9b0",
      "patch": "@@ -73,11 +73,11 @@ Thumbs.db\n # Vendor submodule build artifacts (never commit upstream changes)\n vendor/*\n # Exception: commit prebuilt libraries for faster CI builds\n-!vendor/prebuilt/\n-!vendor/prebuilt/**\n+!prebuilt/\n+!prebuilt/**\n # But still ignore OS metadata in prebuilt\n-vendor/prebuilt/.DS_Store\n-vendor/prebuilt/**/.DS_Store\n+prebuilt/.DS_Store\n+prebuilt/**/.DS_Store\n \n # Test files should be in test/ directory\n /test_*.js.env"
    },
    {
      "sha": "1e18002258943240c72ea71262dccb2433e21a32",
      "filename": "build.zig",
      "status": "modified",
      "additions": 4,
      "deletions": 4,
      "changes": 8,
      "blob_url": "https://github.com/teamchong/edgebox/blob/1429bb493a8ad0464cb73119a776353e2846c9b0/build.zig",
      "raw_url": "https://github.com/teamchong/edgebox/raw/1429bb493a8ad0464cb73119a776353e2846c9b0/build.zig",
      "contents_url": "https://api.github.com/repos/teamchong/edgebox/contents/build.zig?ref=1429bb493a8ad0464cb73119a776353e2846c9b0",
      "patch": "@@ -15,13 +15,13 @@ pub fn build(b: *std.Build) void {\n         const cpu_arch = target.result.cpu.arch;\n \n         if (os_tag == .macos and cpu_arch == .aarch64) {\n-            break :blk \"vendor/prebuilt/darwin-arm64\";\n+            break :blk \"prebuilt/darwin-arm64\";\n         } else if (os_tag == .macos and cpu_arch == .x86_64) {\n-            break :blk \"vendor/prebuilt/darwin-x64\";\n+            break :blk \"prebuilt/darwin-x64\";\n         } else if (os_tag == .linux and cpu_arch == .aarch64) {\n-            break :blk \"vendor/prebuilt/linux-arm64\";\n+            break :blk \"prebuilt/linux-arm64\";\n         } else if (os_tag == .linux and cpu_arch == .x86_64) {\n-            break :blk \"vendor/prebuilt/linux-x64\";\n+            break :blk \"prebuilt/linux-x64\";\n         } else {\n             break :blk null;\n         }"
    },
