      "patch": "@@ -789,6 +789,62 @@\n     \"binary_expression\": {\n       \"type\": \"CHOICE\",\n       \"members\": [\n+        {\n+          \"type\": \"PREC_LEFT\",\n+          \"value\": 1,\n+          \"content\": {\n+            \"type\": \"SEQ\",\n+            \"members\": [\n+              {\n+                \"type\": \"SYMBOL\",\n+                \"name\": \"expression\"\n+              },\n+              {\n+                \"type\": \"STRING\",\n+                \"value\": \"else\"\n+              },\n+              {\n+                \"type\": \"REPEAT\",\n+                \"content\": {\n+                  \"type\": \"STRING\",\n+                  \"value\": \"\\n\"\n+                }\n+              },\n+              {\n+                \"type\": \"SYMBOL\",\n+                \"name\": \"expression\"\n+              }\n+            ]\n+          }\n+        },\n+        {\n+          \"type\": \"PREC_LEFT\",\n+          \"value\": 2,\n+          \"content\": {\n+            \"type\": \"SEQ\",\n+            \"members\": [\n+              {\n+                \"type\": \"SYMBOL\",\n+                \"name\": \"expression\"\n+              },\n+              {\n+                \"type\": \"STRING\",\n+                \"value\": \"if\"\n+              },\n+              {\n+                \"type\": \"REPEAT\",\n+                \"content\": {\n+                  \"type\": \"STRING\",\n+                  \"value\": \"\\n\"\n+                }\n+              },\n+              {\n+                \"type\": \"SYMBOL\",\n+                \"name\": \"expression\"\n+              }\n+            ]\n+          }\n+        },\n         {\n           \"type\": \"PREC_LEFT\",\n           \"value\": 3,\n@@ -881,6 +937,47 @@\n                   {\n                     \"type\": \"STRING\",\n                     \"value\": \"<=\"\n+                  },\n+                  {\n+                    \"type\": \"STRING\",\n+                    \"value\": \"in\"\n+                  }\n+                ]\n+              },\n+              {\n+                \"type\": \"REPEAT\",\n+                \"content\": {\n+                  \"type\": \"STRING\",\n+                  \"value\": \"\\n\"\n+                }\n+              },\n+              {\n+                \"type\": \"SYMBOL\",\n+                \"name\": \"expression\"\n+              }\n+            ]\n+          }\n+        },\n+        {\n+          \"type\": \"PREC_LEFT\",\n+          \"value\": 6,\n+          \"content\": {\n+            \"type\": \"SEQ\",\n+            \"members\": [\n+              {\n+                \"type\": \"SYMBOL\",\n+                \"name\": \"expression\"\n+              },\n+              {\n+                \"type\": \"SEQ\",\n+                \"members\": [\n+                  {\n+                    \"type\": \"STRING\",\n+                    \"value\": \"not\"\n+                  },\n+                  {\n+                    \"type\": \"STRING\",\n+                    \"value\": \"in\"\n                   }\n                 ]\n               },"
