      "deletions": 3,
      "changes": 6,
      "blob_url": "https://github.com/philipp-spiess/openfuse/blob/63bcbf92d7afd90b527b1524ffbfa224ca0d92ab/Dockerfile.test",
      "raw_url": "https://github.com/philipp-spiess/openfuse/raw/63bcbf92d7afd90b527b1524ffbfa224ca0d92ab/Dockerfile.test",
      "contents_url": "https://api.github.com/repos/philipp-spiess/openfuse/contents/Dockerfile.test?ref=63bcbf92d7afd90b527b1524ffbfa224ca0d92ab",
      "patch": "@@ -1,7 +1,7 @@\n FROM node:22-bookworm-slim\n \n-# Install libfuse2 + build tools for compiling fuse-native from source (arm64)\n-RUN apt-get update && apt-get install -y libfuse-dev fuse pkg-config && rm -rf /var/lib/apt/lists/*\n+# Install libfuse2 + build tooling for fuse-native\n+RUN apt-get update && apt-get install -y libfuse-dev fuse pkg-config python3 make g++ && rm -rf /var/lib/apt/lists/*\n \n # Install Bun\n RUN npm install -g bun\n@@ -27,4 +27,4 @@ RUN cd packages/@openfuse/fuse && \\\n     cc -shared -o src/bridge/fuse_bridge.so src/bridge/fuse_bridge.c \\\n     $(pkg-config --cflags --libs fuse) -fPIC -pthread\n \n-CMD [\"node\", \"test/node-mount-test.mjs\"]\n+CMD [\"node\", \"tests/node-mount-test.ts\"]"
    },
    {
      "sha": "96e0424c11077f9aaf1277630c1b23c1588494ef",
      "filename": "README.md",
      "status": "modified",
      "additions": 9,
      "deletions": 8,
      "changes": 17,
      "blob_url": "https://github.com/philipp-spiess/openfuse/blob/63bcbf92d7afd90b527b1524ffbfa224ca0d92ab/README.md",
      "raw_url": "https://github.com/philipp-spiess/openfuse/raw/63bcbf92d7afd90b527b1524ffbfa224ca0d92ab/README.md",
      "contents_url": "https://api.github.com/repos/philipp-spiess/openfuse/contents/README.md?ref=63bcbf92d7afd90b527b1524ffbfa224ca0d92ab",
      "patch": "@@ -87,6 +87,7 @@ openfuse/\n \u2502       \u251c\u2500\u2500 fuse/\n \u2502       \u2514\u2500\u2500 fskit/\n \u251c\u2500\u2500 examples/\n+\u251c\u2500\u2500 tests/\n \u251c\u2500\u2500 Dockerfile.test\n \u251c\u2500\u2500 docker-compose.test.yml\n \u2514\u2500\u2500 .github/workflows/ci.yml\n@@ -95,17 +96,17 @@ openfuse/\n ## Commands\n \n ```bash\n-# Run all tests\n+# Run all unit tests (Bun test runner)\n bun test\n \n-# Run unit tests only\n-bun test --filter core\n-\n-# Run integration test file (guarded unless OPENFUSE_RUN_MOUNT_TESTS=1)\n-bun test --filter mount\n+# Run the core unit test file directly\n+bun test packages/openfuse/test/core.test.ts\n \n # Build all workspace packages\n bun run build\n+\n+# Run Linux mount e2e script (Node.js 22+, requires FUSE)\n+node tests/node-mount-test.ts\n ```\n \n ## Docker Linux Test Setup\n@@ -117,8 +118,8 @@ docker compose -f docker-compose.test.yml up --build\n ## CI\n \n GitHub Actions runs:\n-- Ubuntu: unit + mount test suite invocation\n-- macOS: unit tests\n+- Unit tests with `bun test` on Ubuntu + macOS\n+- Linux mount e2e script (`node tests/node-mount-test.ts`)\n \n ## License\n "
    },
