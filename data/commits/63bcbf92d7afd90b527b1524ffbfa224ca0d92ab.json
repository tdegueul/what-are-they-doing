{
  "message": "test: migrate to bun tests and ts e2e workflow\n\n\ud83d\udd2e View transcript: https://agentlogs.ai/s/iioub2jlyiio4ybqvn9wgh5c",
  "files": [
    {
      "sha": "0b0776d5f53d37c1e3a4826f555d87f39156d361",
      "filename": ".github/workflows/ci.yml",
      "status": "modified",
      "additions": 34,
      "deletions": 15,
      "changes": 49,
      "blob_url": "https://github.com/philipp-spiess/openfuse/blob/63bcbf92d7afd90b527b1524ffbfa224ca0d92ab/.github%2Fworkflows%2Fci.yml",
      "raw_url": "https://github.com/philipp-spiess/openfuse/raw/63bcbf92d7afd90b527b1524ffbfa224ca0d92ab/.github%2Fworkflows%2Fci.yml",
      "contents_url": "https://api.github.com/repos/philipp-spiess/openfuse/contents/.github%2Fworkflows%2Fci.yml?ref=63bcbf92d7afd90b527b1524ffbfa224ca0d92ab",
      "patch": "@@ -3,38 +3,57 @@ name: CI\n on: [push, pull_request]\n \n jobs:\n-  test:\n+  unit:\n     strategy:\n       matrix:\n-        runtime: [bun, node]\n+        os: [ubuntu-latest, macos-latest]\n \n+    runs-on: ${{ matrix.os }}\n+\n+    steps:\n+      - uses: actions/checkout@v4\n+\n+      - name: Setup Bun\n+        uses: oven-sh/setup-bun@v2\n+\n+      - name: Install dependencies\n+        run: bun install\n+\n+      - name: Unit tests (Bun)\n+        run: bun test packages/openfuse/test/core.test.ts\n+\n+  e2e-linux-node:\n     runs-on: ubuntu-latest\n \n     steps:\n       - uses: actions/checkout@v4\n \n       - name: Setup Bun\n-        if: matrix.runtime == 'bun'\n         uses: oven-sh/setup-bun@v2\n \n       - name: Setup Node\n-        if: matrix.runtime == 'node'\n         uses: actions/setup-node@v4\n         with:\n           node-version: 22\n \n-      - name: Install dependencies (Bun)\n-        if: matrix.runtime == 'bun'\n+      - name: Install FUSE + build tooling (Linux)\n+        run: |\n+          sudo apt-get update\n+          sudo apt-get install -y libfuse-dev fuse3 pkg-config python3 make g++\n+\n+      - name: Install workspace dependencies (Bun)\n         run: bun install\n \n-      - name: Install dependencies (Node)\n-        if: matrix.runtime == 'node'\n-        run: npm install\n+      - name: Install fuse-native for Node backend\n+        run: |\n+          mkdir -p /tmp/openfuse-fuse-deps\n+          npm install --prefix /tmp/openfuse-fuse-deps fuse-native\n+          mkdir -p packages/@openfuse/fuse/node_modules\n+          rm -rf packages/@openfuse/fuse/node_modules/fuse-native\n+          ln -s /tmp/openfuse-fuse-deps/node_modules/fuse-native packages/@openfuse/fuse/node_modules/fuse-native\n \n-      - name: Unit tests (Bun)\n-        if: matrix.runtime == 'bun'\n-        run: bunx vitest run\n+      - name: Build packages\n+        run: bun run build\n \n-      - name: Unit tests (Node)\n-        if: matrix.runtime == 'node'\n-        run: npx vitest run\n+      - name: Run e2e mount test (Node)\n+        run: node tests/node-mount-test.ts"
    },
    {
