      "patch": "@@ -1,6 +1,25 @@\n <?xml version=\"1.0\" standalone=\"yes\"?>\n <rss xmlns:sparkle=\"http://www.andymatuschak.org/xml-namespaces/sparkle\" version=\"2.0\">\n     <channel>\n+        <item>\n+            <title>0.7.0</title>\n+            <pubDate>Tue, 30 Dec 2025 03:43:38 +0100</pubDate>\n+            <link>https://raw.githubusercontent.com/steipete/Trimmy/main/appcast.xml</link>\n+            <sparkle:version>27</sparkle:version>\n+            <sparkle:shortVersionString>0.7.0</sparkle:shortVersionString>\n+            <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>\n+            <description><![CDATA[<h2>Trimmy 0.7.0</h2>\n+<ul>\n+<li><strong>Highlight:</strong> Context-aware trimming with terminal detection, plus per-terminal aggressiveness (Cmd-C tracking + frontmost-app fallback).</li>\n+<li>Terminal detection now covers Ghostty, WezTerm, Alacritty, Hyper, and Warp Stable bundle IDs for context-aware trimming.</li>\n+<li>Aggressiveness now splits between general apps and terminals (defaults: Low + Normal), plus a \u201cNone\u201d option to disable auto-trim in regular apps.</li>\n+<li>Settings: added Advanced tab and moved CLI installer, debug tools, and clipboard fallbacks there.</li>\n+<li>Menu bar icon now animates whenever a trim happens.</li>\n+</ul>\n+<p><a href=\"https://github.com/steipete/Trimmy/blob/main/CHANGELOG.md\">View full changelog</a></p>\n+]]></description>\n+            <enclosure url=\"https://github.com/steipete/Trimmy/releases/download/v0.7.0/Trimmy-0.7.0.zip\" length=\"2600177\" type=\"application/octet-stream\" sparkle:edSignature=\"B+bEH+Xyqqaj6TiufWSyxHl0Ag1oKCrR32RGAlFa2kQQ9E3ahzAemQ49ZW6yUEWHNG/jJMJKq/3vVQ8AGj+tDw==\"/>\n+        </item>\n         <item>\n             <title>0.6.4</title>\n             <pubDate>Fri, 26 Dec 2025 20:02:50 +0100</pubDate>\n@@ -18,7 +37,6 @@\n             ]]></description>\n             <enclosure url=\"https://github.com/steipete/Trimmy/releases/download/v0.6.4/Trimmy-