      "patch": "@@ -0,0 +1,14 @@\n+#!/usr/bin/env bash\n+set -euo pipefail\n+\n+if [[ $# -lt 2 ]]; then\n+  echo \"usage: $0 \\\"type: message\\\" <path...>\" >&2\n+  exit 2\n+fi\n+\n+msg=\"$1\"\n+shift\n+\n+git add -- \"$@\"\n+git commit -m \"$msg\" -- \"$@\"\n+"
