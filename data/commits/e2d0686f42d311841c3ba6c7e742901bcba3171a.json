      "contents_url": "https://api.github.com/repos/Dicklesworthstone/jeffreysprompts.com/contents/apps%2Fweb%2Fvitest.config.ts?ref=e2d0686f42d311841c3ba6c7e742901bcba3171a",
      "patch": "@@ -17,5 +17,22 @@ export default defineConfig({\n     alias: {\n       \"framer-motion\": path.resolve(__dirname, \"./src/__mocks__/framer-motion.tsx\"),\n     },\n+    coverage: {\n+      provider: \"v8\",\n+      reporter: [\"text\", \"json\", \"html\"],\n+      reportsDirectory: \"./coverage\",\n+      include: [\"src/**/*.{ts,tsx}\"],\n+      exclude: [\n+        \"src/**/*.test.{ts,tsx}\",\n+        \"src/**/__mocks__/**\",\n+        \"src/types/**\",\n+      ],\n+      thresholds: {\n+        lines: 50,\n+        branches: 50,\n+        functions: 50,\n+        statements: 50,\n+      },\n+    },\n   },\n });"
    },
