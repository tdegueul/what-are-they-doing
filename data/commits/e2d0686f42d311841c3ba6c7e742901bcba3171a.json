{
  "message": "Add E2E tests, coverage reporting, and pre-release gates to CI\n\nCI Improvements:\n- Add E2E test job that runs Playwright and CLI E2E tests\n- Upload test artifacts on failure for debugging\n- Run tests with coverage and upload coverage reports\n\nCoverage Configuration:\n- Add Vitest coverage with v8 provider\n- Configure 50% threshold for lines, branches, functions\n- Add @vitest/coverage-v8 dependency\n\nRelease Gates:\n- Add pre-release-tests job that runs all tests before building\n- Block release builds until all tests pass\n- Ensure no broken code reaches production\n\nCo-Authored-By: Claude Opus 4.5 <noreply@anthropic.com>",
  "files": [
    {
      "sha": "6c73957111b14bd3eab02542f61fe4d49a625760",
      "filename": ".github/workflows/ci.yml",
      "status": "modified",
      "additions": 34,
      "deletions": 2,
      "changes": 36,
      "blob_url": "https://github.com/Dicklesworthstone/jeffreysprompts.com/blob/e2d0686f42d311841c3ba6c7e742901bcba3171a/.github%2Fworkflows%2Fci.yml",
      "raw_url": "https://github.com/Dicklesworthstone/jeffreysprompts.com/raw/e2d0686f42d311841c3ba6c7e742901bcba3171a/.github%2Fworkflows%2Fci.yml",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/jeffreysprompts.com/contents/.github%2Fworkflows%2Fci.yml?ref=e2d0686f42d311841c3ba6c7e742901bcba3171a",
      "patch": "@@ -34,10 +34,16 @@ jobs:\n           bun-version: latest\n       - name: Install dependencies\n         run: bun install --frozen-lockfile\n-      - name: Web tests\n-        run: bun run test\n+      - name: Web tests with coverage\n+        run: bun run test:coverage\n       - name: CLI tests\n         run: bun run test:cli\n+      - name: Upload coverage report\n+        uses: actions/upload-artifact@v4\n+        with:\n+          name: coverage-report\n+          path: apps/web/coverage/\n+          retention-days: 7\n \n   build:\n     runs-on: ubuntu-latest\n@@ -66,3 +72,29 @@ jobs:\n         run: bun run --cwd packages/core typecheck\n       - name: CLI typecheck\n         run: bun run --cwd packages/cli typecheck\n+\n+  e2e:\n+    runs-on: ubuntu-latest\n+    needs: [build]\n+    steps:\n+      - uses: actions/checkout@v4\n+      - uses: oven-sh/setup-bun@v2\n+        with:\n+          bun-version: latest\n+      - name: Install dependencies\n+        run: bun install --frozen-lockfile\n+      - name: Install Playwright browsers\n+        run: bunx playwright install --with-deps chromium\n+      - name: Run CLI E2E tests\n+        run: bun run test:e2e:cli\n+      - name: Run Web E2E tests\n+        run: bun run test:e2e:web\n+      - name: Upload test artifacts on failure\n+        if: failure()\n+        uses: actions/upload-artifact@v4\n+        with:\n+          name: e2e-test-artifacts\n+          path: |\n+            test-results/\n+            playwright-report/\n+          retention-days: 7"
    },
    {
      "sha": "ce085d6fb8b7e20f09a7ad4b0898ddd5efc6a54a",
      "filename": ".github/workflows/release.yml",
      "status": "modified",
      "additions": 21,
      "deletions": 0,
      "changes": 21,
      "blob_url": "https://github.com/Dicklesworthstone/jeffreysprompts.com/blob/e2d0686f42d311841c3ba6c7e742901bcba3171a/.github%2Fworkflows%2Frelease.yml",
      "raw_url": "https://github.com/Dicklesworthstone/jeffreysprompts.com/raw/e2d0686f42d311841c3ba6c7e742901bcba3171a/.github%2Fworkflows%2Frelease.yml",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/jeffreysprompts.com/contents/.github%2Fworkflows%2Frelease.yml?ref=e2d0686f42d311841c3ba6c7e742901bcba3171a",
      "patch": "@@ -9,8 +9,29 @@ permissions:\n   contents: write\n \n jobs:\n+  # Run all tests before building release artifacts\n+  pre-release-tests:\n+    name: Pre-Release Tests\n+    runs-on: ubuntu-latest\n+    steps:\n+      - uses: actions/checkout@v4\n+      - uses: oven-sh/setup-bun@v2\n+        with:\n+          bun-version: latest\n+      - name: Install dependencies\n+        run: bun install --frozen-lockfile\n+      - name: Run unit tests\n+        run: bun run test && bun run test:cli\n+      - name: Install Playwright browsers\n+        run: bunx playwright install --with-deps chromium\n+      - name: Run E2E tests\n+        run: bun run test:e2e:cli && bun run test:e2e:web\n+      - name: Run typecheck\n+        run: bun run --cwd packages/core typecheck && bun run --cwd packages/cli typecheck\n+\n   build:\n     name: Build (${{ matrix.target }})\n+    needs: pre-release-tests\n     runs-on: ${{ matrix.os }}\n     strategy:\n       fail-fast: false"
    },
    {
      "sha": "a10b82fcee3055c704bef630440e3a65d246893e",
      "filename": "apps/web/package.json",
      "status": "modified",
      "additions": 3,
      "deletions": 1,
      "changes": 4,
      "blob_url": "https://github.com/Dicklesworthstone/jeffreysprompts.com/blob/e2d0686f42d311841c3ba6c7e742901bcba3171a/apps%2Fweb%2Fpackage.json",
      "raw_url": "https://github.com/Dicklesworthstone/jeffreysprompts.com/raw/e2d0686f42d311841c3ba6c7e742901bcba3171a/apps%2Fweb%2Fpackage.json",
      "contents_url": "https://api.github.com/repos/Dicklesworthstone/jeffreysprompts.com/contents/apps%2Fweb%2Fpackage.json?ref=e2d0686f42d311841c3ba6c7e742901bcba3171a",
      "patch": "@@ -11,7 +11,8 @@\n     \"lint:ox\": \"oxlint\",\n     \"lint:all\": \"eslint && oxlint\",\n     \"test\": \"vitest run\",\n-    \"test:watch\": \"vitest\"\n+    \"test:watch\": \"vitest\",\n+    \"test:coverage\": \"vitest run --coverage\"\n   },\n   \"dependencies\": {\n     \"@jeffreysprompts/core\": \"workspace:*\",\n@@ -48,6 +49,7 @@\n     \"@types/react-dom\": \"^19\",\n     \"@types/react-syntax-highlighter\": \"^15.5.13\",\n     \"@vitejs/plugin-react\": \"^5.1.2\",\n+    \"@vitest/coverage-v8\": \"^4.0.16\",\n     \"eslint\": \"^9\",\n     \"eslint-config-next\": \"16.1.1\",\n     \"happy-dom\": \"^20.1.0\","
    },
