                                   </span>\n+                                            {{else if eq .Status \"failed\"}}\n+                                            <span class=\"inline-flex items-center gap-1 text-red-700\">\n+                                                <span class=\"w-2 h-2 bg-red-500 rounded-full\"></span>\n+                                                failed\n+                                            </span>\n+                                            {{else}}\n+                                            <span class=\"text-gray-500\">{{.Status}}</span>\n+                                            {{end}}\n+                                        </td>\n+                                        <td class=\"px-4 py-2 whitespace-nowrap text-sm\" x-data=\"{ actionsOpen: false }\" @click.stop>\n+                                            <div class=\"relative\">\n+                                                <button @click=\"actionsOpen = !actionsOpen\" @click.outside=\"actionsOpen = false\" class=\"text-gray-500 hover:text-gray-700\">\n+                                                    <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                                                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z\"/>\n+                                                    </svg>\n+                                                </button>\n+                                                <div x-show=\"actionsOpen\" x-cloak class=\"absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg border border-gray-200 z-10\">\n+                                                    <div class=\"py-1\">\n+                                                        <button @click=\"copySSH('{{.TailscaleHost}}')\" class=\"block w-full text-le