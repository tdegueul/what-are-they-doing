      "patch": "@@ -0,0 +1,77 @@\n+<div class=\"space-y-4\">\n+    <div class=\"flex items-center justify-between\">\n+        <div>\n+            <h2 class=\"text-lg font-bold text-gray-900\">{{.Task.ID}}</h2>\n+            <p class=\"text-sm text-gray-500\">{{.Task.RepoURL}}</p>\n+        </div>\n+        {{if eq .Task.Status \"running\"}}\n+        <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800\">\n+            <span class=\"w-2 h-2 bg-green-500 rounded-full mr-1.5 animate-pulse\"></span>\n+            running\n+        </span>\n+        {{else if eq .Task.Status \"stopped\"}}\n+        <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800\">\n+            <span class=\"w-2 h-2 bg-gray-400 rounded-full mr-1.5\"></span>\n+            stopped\n+        </span>\n+        {{else if eq .Task.Status \"failed\"}}\n+        <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800\">\n+            <span class=\"w-2 h-2 bg-red-500 rounded-full mr-1.5\"></span>\n+            failed\n+        </span>\n+        {{else}}\n+        <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800\">\n+            {{.Task.Status}}\n+        </span>\n+        {{end}}\n+    </div>\n+\n+    <!-- Quick metrics grid -->\n+    <div class=\"grid grid-cols-2 gap-2\">\n+        <div class=\"p-3 bg-white rounded-lg border border-gray-200 text-center\">\n+            <div class=\"text-lg font-bold text-gray-900\" id=\"preview-cpu\">--</div>\n+            <div class=\"text-xs text-gray-500\">CPU</div>\n+        </div>\n+        <div class=\"p-3 bg-white rounded-lg border border-gray-200 text-center\">\n+            <div class=\"text-lg font-bold text-gray-900\" id=\"preview-memory\">--</div>\n+            <div class=\"text-xs text-gray-500\">Memory</div>\n+        </div>\n+    </div>\n+\n+    <!-- Details -->\n+    <div class=\"bg-white rounded-lg border border-gray-200 p-3\">\n+        <dl class=\"space-y-2 text-sm\">\n+            {{if .Task.Name}}\n+            <div class=\"flex justify-between\">\n+                <dt class=\"text-gray-500\">Name</dt>\n+                <dd class=\"text-gray-900 font-medium\">{{.Task.Name}}</dd>\n+            </div>\n+            {{end}}\n+            {{if .Task.GitRef}}\n+            <div class=\"flex justify-between\">\n+                <dt class=\"text-gray-500\">Git Ref</dt>\n+                <dd class=\"text-gray-900 font-mono text-xs\">{{.Task.GitRef}}</dd>\n+            </div>\n+            {{end}}\n+            <div class=\"flex justify-between\">\n+                <dt class=\"text-gray-500\">Snapshots</dt>\n+                <dd class=\"text-gray-900\">{{len .Snapshots}}</dd>\n+            </div>\n+        </dl>\n+    </div>\n+\n+    <!-- Recent logs placeholder -->\n+    <div class=\"bg-gray-900 text-gray-300 rounded-lg p-3 font-mono text-xs h-32 overflow-auto\">\n+        <p class=\"text-gray-500\">Connecting...</p>\n+    </div>\n+\n+    <!-- Actions -->\n+    <div class=\"flex gap-2\">\n+        <button onclick=\"copySSH('{{.Task.TailscaleHost}}')\" class=\"flex-1 px-3 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors\">\n+            Copy SSH\n+        </button>\n+        <a href=\"/vm/{{.Task.ID}}\" class=\"flex-1 px-3 py-2 bg-gray-200 text-gray-800 text-sm font-medium rounded-lg text-center hover:bg-gray-300 transition-colors\">\n+            Full Details\n+        </a>\n+    </div>\n+</div>"
    }
  ]
}
