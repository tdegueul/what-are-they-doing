 class=\"flex items-center gap-2\">\n-                            <svg class=\"w-4 h-4 transition-transform\" :class=\"{ 'rotate-90': open }\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n-                                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n-                            </svg>\n-                            <span class=\"font-medium text-gray-900\">{{$repo}}</span>\n-                            <span class=\"text-sm text-gray-500\">({{len $tasks}} VMs)</span>\n-                        </div>\n-                    </button>\n-                    <div x-show=\"open\" x-cloak class=\"border-t border-gray-200\">\n-                        <table class=\"min-w-full divide-y divide-gray-200\">\n-                            <thead class=\"bg-gray-50\">\n-                                <tr>\n-                                    <th class=\"px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\">ID</th>\n-                                    <th class=\"px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\">Name</th>\n-                                    <th class=\"px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\">Status</th>\n-                                    <th class=\"px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\">Actions</th>\n-                                </tr>\n-                            </thead>\n-                            <tbody class=\"bg-white divide-y divide-gray-200\">\n-                                {{range $tasks}}\n-                                <tr class=\"hover:bg-gray-50\">\n-                                    <td class=\"px-4 py-2 whitespace-nowrap\">\n-                                        <a href=\"/vm/{{.ID}}\" class=\"text-blue-600 hover:text-blue-800 hover:underline\">{{.ID}}</a>\n-                                    </td>\n-   