      "raw_url": "https://github.com/tenzir/claude-plugins/raw/5fbb270623ca4e8db16c127073a6f427ea5863eb/plugins%2Fchangelog%2Fchangelog%2Freleases%2Fv1.4.0%2Fmanifest.yaml",
