      "raw_url": "https://github.com/tenzir/claude-plugins/raw/5fbb270623ca4e8db16c127073a6f427ea5863eb/plugins%2Fdocs%2Fchangelog%2Freleases%2Fv2.1.0%2Fnotes.md",
