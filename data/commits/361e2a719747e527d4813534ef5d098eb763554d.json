      "patch": "@@ -0,0 +1,17 @@\n+//go:build !windows\n+\n+package signals\n+\n+import (\n+\t\"os\"\n+\t\"testing\"\n+)\n+\n+func TestIsProcessAlive(t *testing.T) {\n+\tif isProcessAlive(-1) {\n+\t\tt.Fatal(\"expected negative pid to be treated as not alive\")\n+\t}\n+\tif !isProcessAlive(os.Getpid()) {\n+\t\tt.Fatal(\"expected current pid to be treated as alive\")\n+\t}\n+}"
