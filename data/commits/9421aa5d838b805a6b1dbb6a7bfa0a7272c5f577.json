{
  "message": "Fix Sparkle public key in release workflow\n\nRemove errant backslash before the secrets substitution - GitHub Actions\nevaluates ${{ }} before the shell runs, so the backslash was being written\nliterally into Info.plist, breaking signature verification.",
  "files": [
    {
      "sha": "03d648d259ce1eaa173849f85ef00aa124a585bc",
      "filename": ".github/workflows/build-and-release.yml",
      "status": "modified",
      "additions": 1,
      "deletions": 1,
      "changes": 2,
      "blob_url": "https://github.com/obra/winby/blob/9421aa5d838b805a6b1dbb6a7bfa0a7272c5f577/.github%2Fworkflows%2Fbuild-and-release.yml",
      "raw_url": "https://github.com/obra/winby/raw/9421aa5d838b805a6b1dbb6a7bfa0a7272c5f577/.github%2Fworkflows%2Fbuild-and-release.yml",
      "contents_url": "https://api.github.com/repos/obra/winby/contents/.github%2Fworkflows%2Fbuild-and-release.yml?ref=9421aa5d838b805a6b1dbb6a7bfa0a7272c5f577",
      "patch": "@@ -174,7 +174,7 @@ jobs:\n             <key>SUFeedURL</key>\n             <string>https://github.com/obra/winby/releases/latest/download/appcast.xml</string>\n             <key>SUPublicEDKey</key>\n-            <string>\\${{ secrets.SPARKLE_PUBLIC_KEY }}</string>\n+            <string>${{ secrets.SPARKLE_PUBLIC_KEY }}</string>\n         </dict>\n         </plist>\n         EOF"
    }
  ]
