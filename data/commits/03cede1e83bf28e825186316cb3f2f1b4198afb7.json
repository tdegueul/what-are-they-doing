      "patch": "@@ -99,5 +99,15 @@\n   \"logging\": {\n     \"file\": \".poltergeist.log\",\n     \"level\": \"debug\"\n-  }\n+  },\n+  \"statusScripts\": [\n+    {\n+      \"label\": \"SwiftLint\",\n+      \"command\": \"./scripts/status-swiftlint.sh\",\n+      \"targets\": [\"peekaboo\", \"peekaboo-mac\"],\n+      \"cooldownSeconds\": 60,\n+      \"timeoutSeconds\": 300,\n+      \"maxLines\": 6\n+    }\n+  ]\n }"
