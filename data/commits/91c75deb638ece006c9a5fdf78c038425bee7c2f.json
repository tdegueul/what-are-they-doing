      "contents_url": "https://api.github.com/repos/prime-radiant-inc/stockyard/contents/pkg%2Fdashboard%2Ftemplates%2Fvm_detail.html?ref=91c75deb638ece006c9a5fdf78c038425bee7c2f",
      "patch": "@@ -249,14 +249,22 @@ <h2 class=\"text-lg font-medium\">Resources</h2>\n                          pendingLines: [],\n                          searchResults: [],\n                          mode: 'live',\n-                         filter: '',\n+                         filterText: '',\n+                         filterStream: 'all',\n                          searchQuery: '',\n                          searchStream: 'all',\n                          paused: false,\n                          connected: false,\n                          searching: false,\n                          maxLogs: 500,\n                          searchTimeout: null,\n+                         get filteredLogs() {\n+                             return this.logs.filter(log => {\n+                                 const matchesStream = this.filterStream === 'all' || log.stream === this.filterStream;\n+                                 const matchesText = !this.filterText || log.line.toLowerCase().includes(this.filterText.toLowerCase());\n+                                 return matchesStream && matchesText;\n+                             });\n+                         },\n                          async searchLogs() {\n                              if (!this.searchQuery.trim()) {\n                                  this.searchResults = [];\n@@ -348,8 +356,14 @@ <h2 class=\"text-lg font-medium\">Logs</h2>\n                         </div>\n                         <!-- Live mode controls -->\n                         <div x-show=\"mode === 'live'\" class=\"flex items-center gap-2\">\n-                            <input type=\"text\" x-model=\"filter\" placeholder=\"Filter live logs...\"\n-                                   class=\"flex-1 px-2 py-1 text-sm border border-gray-300 rounded\">\n+                            <input type=\"text\" x-model=\"filterText\"\n+                                   placeholder=\"Filter current logs...\"\n+                                   class=\"flex-1 px-3 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500\">\n+                            <select x-model=\"filterStream\" class=\"px-2 py-1 text-sm border border-gray-300 rounded\">\n+                                <option value=\"all\">All</option>\n+                                <option value=\"stdout\">stdout</option>\n+                                <option value=\"stderr\">stderr</option>\n+                            </select>\n                             <button @click=\"paused = !paused; if (!paused) { logs = logs.concat(pendingLines).slice(-maxLogs); pendingLines = []; $nextTick(() => { const el = $refs.logContainer; if (el) el.scrollTop = el.scrollHeight; }); }\"\n                                     :class=\"paused ? 'bg-yellow-100 text-yellow-700' : 'bg-gray-100 text-gray-600'\"\n                                     class=\"px-2 py-1 text-xs rounded flex items-center gap-1\">\n@@ -389,7 +403,7 @@ <h2 class=\"text-lg font-medium\">Logs</h2>\n                             <template x-if=\"logs.length === 0\">\n                                 <p class=\"text-gray-500\">Waiting for logs...</p>\n                             </template>\n-                            <template x-for=\"log in logs.filter(l => !filter || l.line.includes(filter))\" :key=\"log.id\">\n+                            <template x-for=\"log in filteredLogs\" :key=\"log.id\">\n                                 <div class=\"flex gap-2 hover:bg-gray-800\">\n                                     <span class=\"text-gray-500 shrink-0\" x-text=\"log.time\"></span>\n                                     <span :class=\"log.stream === 'stderr' ? 'text-red-400' : 'text-gray-300'\" x-text=\"log.line\"></span>"
