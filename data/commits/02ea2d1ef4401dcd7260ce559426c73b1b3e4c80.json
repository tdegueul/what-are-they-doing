      "contents_url": "https://api.github.com/repos/agentlogs/agentlogs/contents/packages%2Fcli%2Fpackage.json?ref=02ea2d1ef4401dcd7260ce559426c73b1b3e4c80",
      "patch": "@@ -2,13 +2,13 @@\n   \"name\": \"agentlogs\",\n   \"version\": \"0.0.1\",\n   \"bin\": {\n-    \"agentlogs\": \"src/index.ts\"\n+    \"agentlogs\": \"dist/index.js\"\n   },\n   \"files\": [\n     \"dist\"\n   ],\n   \"type\": \"module\",\n-  \"main\": \"src/index.ts\",\n+  \"main\": \"dist/index.js\",\n   \"publishConfig\": {\n     \"access\": \"public\",\n     \"bin\": {"
