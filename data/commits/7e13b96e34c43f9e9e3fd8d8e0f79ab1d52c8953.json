      "patch": "@@ -0,0 +1,10 @@\n+#!/usr/bin/env bash\n+\n+set -euo pipefail\n+\n+ROOT=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\"\n+\n+cd \"$ROOT\"\n+\n+echo \"Rebuilding and running tmuxwatch with cache disabled...\"\n+exec env GOCACHE=off go run ./cmd/tmuxwatch \"$@\""
