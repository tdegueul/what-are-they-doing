      "additions": 5,
      "deletions": 5,
      "changes": 10,
      "blob_url": "https://github.com/tenzir/claude-plugins/blob/412d6d56db340cc7db412124f8a449e0b42bfac9/.claude-plugin%2Fmarketplace.json",
      "raw_url": "https://github.com/tenzir/claude-plugins/raw/412d6d56db340cc7db412124f8a449e0b42bfac9/.claude-plugin%2Fmarketplace.json",
