      "patch": "@@ -12,27 +12,27 @@\n     {\n       \"name\": \"auto-update\",\n       \"description\": \"Auto-update the tenzir marketplace on session start\",\n-      \"source\": \"./auto-update\"\n+      \"source\": \"./plugins/auto-update\"\n     },\n     {\n       \"name\": \"changelog\",\n       \"description\": \"Manage changelogs and release notes with tenzir-changelog\",\n-      \"source\": \"./changelog\"\n+      \"source\": \"./plugins/changelog\"\n     },\n     {\n       \"name\": \"formatter\",\n       \"description\": \"Auto-format files after Claude edits\",\n-      \"source\": \"./formatter\"\n+      \"source\": \"./plugins/formatter\"\n     },\n     {\n       \"name\": \"git\",\n       \"description\": \"Git workflows for Tenzir repositories\",\n-      \"source\": \"./git\"\n+      \"source\": \"./plugins/git\"\n     },\n     {\n       \"name\": \"python\",\n       \"description\": \"Python coding conventions for Tenzir projects\",\n-      \"source\": \"./python\"\n+      \"source\": \"./plugins/python\"\n     }\n   ]\n }"
    },
