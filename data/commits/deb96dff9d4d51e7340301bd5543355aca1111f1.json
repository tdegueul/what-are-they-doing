      "contents_url": "https://api.github.com/repos/Dicklesworthstone/jeffreysprompts.com/contents/apps%2Fweb%2F.gitignore?ref=deb96dff9d4d51e7340301bd5543355aca1111f1",
      "patch": "@@ -39,3 +39,4 @@ yarn-error.log*\n # typescript\n *.tsbuildinfo\n next-env.d.ts\n+.env*.local"
    },
