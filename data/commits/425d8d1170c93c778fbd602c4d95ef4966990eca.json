{
  "message": "fix(ci): set working-directory: / for disk cleanup step\n\nThe free disk space step runs before checkout, so the default\nworking-directory (pi_agent_rust) doesn't exist yet. Override to /\nso the step can run from the filesystem root.\n\nCo-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>",
  "files": [
    {
      "sha": "f8714ab72319fd25b4cad4c15b040251f915d8ce",
      "filename": ".github/workflows/bench.yml",
      "status": "modified",
      "additions": 1,
      "deletions": 0,
      "changes": 1,
      "blob_url": "https://github.com/Dicklesworthstone/pi_agent_rust/blob/425d8d1170c93c778fbd602c4d95ef4966990eca/.github%2Fworkflows%2Fbench.yml",
