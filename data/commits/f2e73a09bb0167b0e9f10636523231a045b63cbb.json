      "additions": 9,
      "deletions": 0,
      "changes": 9,
      "blob_url": "https://github.com/Dicklesworthstone/pi_agent_rust/blob/f2e73a09bb0167b0e9f10636523231a045b63cbb/src%2Ftools.rs",
