      "deletions": 0,
      "changes": 29,
      "blob_url": "https://github.com/tenzir/claude-plugins/blob/36f6d4651dc6c242b93467da401c5c5baa603e3c/plugins%2Fchangelog%2Fchangelog%2Freleases%2Fv1.1.0%2Fnotes.md",
