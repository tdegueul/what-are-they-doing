      "raw_url": "https://github.com/tenzir/claude-plugins/raw/126d7566ec770c95b71ccaab916fcc113b186513/plugins%2Fchangelog%2Fchangelog%2Freleases%2Fv1.3.0%2Fmanifest.yaml",
