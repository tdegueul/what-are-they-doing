      "patch": "@@ -0,0 +1,228 @@\n+<!DOCTYPE html>\n+<html lang=\"en\">\n+<head>\n+    <meta charset=\"UTF-8\">\n+    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n+    <title>{{.Title}} - Stockyard</title>\n+    <script src=\"https://unpkg.com/htmx.org@1.9.10\"></script>\n+    <script defer src=\"https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js\"></script>\n+    <script src=\"https://cdn.tailwindcss.com\"></script>\n+    <style>\n+        [x-cloak] { display: none !important; }\n+    </style>\n+</head>\n+<body class=\"bg-gray-50 text-gray-900 h-screen flex flex-col\">\n+    <!-- Top bar -->\n+    <header class=\"bg-white border-b border-gray-200 px-4 py-2 flex items-center justify-between\">\n+        <div class=\"flex items-center gap-4\">\n+            <a href=\"/\" class=\"p-2 hover:bg-gray-100 rounded flex items-center gap-2 text-gray-600 hover:text-gray-900\">\n+                <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M10 19l-7-7m0 0l7-7m-7 7h18\"/>\n+                </svg>\n+                <span class=\"text-sm\">Back to Fleet</span>\n+            </a>\n+            <span class=\"font-semibold text-lg\">Stockyard</span>\n+        </div>\n+        <div class=\"flex items-center gap-4\">\n+            <span class=\"text-sm text-gray-600\">{{.User}}</span>\n+        </div>\n+    </header>\n+\n+    <div class=\"flex flex-1 overflow-hidden\">\n+        <!-- Sidebar -->\n+        <nav id=\"sidebar\" class=\"w-48 bg-white border-r border-gray-200 flex flex-col\">\n+            <div class=\"flex-1 py-4\">\n+                <a href=\"/\" class=\"flex items-center gap-3 px-4 py-2 text-gray-700 hover:bg-gray-100 {{if eq .ActiveNav \"fleet\"}}bg-blue-50 text-blue-700 border-r-2 border-blue-700{{end}}\">\n+                    <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z\"/>\n+                    </svg>\n+                    <span>Fleet</span>\n+                </a>\n+                <a href=\"/activity\" class=\"flex items-center gap-3 px-4 py-2 text-gray-700 hover:bg-gray-100 {{if eq .ActiveNav \"activity\"}}bg-blue-50 text-blue-700 border-r-2 border-blue-700{{end}}\">\n+                    <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z\"/>\n+                    </svg>\n+                    <span>Activity</span>\n+                </a>\n+                <a href=\"/settings\" class=\"flex items-center gap-3 px-4 py-2 text-gray-700 hover:bg-gray-100 {{if eq .ActiveNav \"settings\"}}bg-blue-50 text-blue-700 border-r-2 border-blue-700{{end}}\">\n+                    <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z\"/>\n+                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\"/>\n+                    </svg>\n+                    <span>Settings</span>\n+                </a>\n+            </div>\n+        </nav>\n+\n+        <!-- Main content -->\n+        <main class=\"flex-1 overflow-auto p-6\">\n+            <!-- Header with VM ID, status, and actions -->\n+            <div class=\"flex items-center justify-between mb-6\">\n+                <div class=\"flex items-center gap-4\">\n+                    <h1 class=\"text-2xl font-semibold\">{{.Task.ID}}</h1>\n+                    {{if eq .Task.Status \"running\"}}\n+                    <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800\">running</span>\n+                    {{else if eq .Task.Status \"stopped\"}}\n+                    <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800\">stopped</span>\n+                    {{else if eq .Task.Status \"failed\"}}\n+                    <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800\">error</span>\n+                    {{else}}\n+                    <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800\">{{.Task.Status}}</span>\n+                    {{end}}\n+                </div>\n+                <div class=\"flex items-center gap-2\">\n+                    <button onclick=\"copySSH('{{.Task.TailscaleHost}}')\" class=\"inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50\">\n+                        <svg class=\"w-4 h-4 mr-2\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3\"/>\n+                        </svg>\n+                        Copy SSH\n+                    </button>\n+                    <div class=\"relative\" x-data=\"{ actionsOpen: false }\">\n+                        <button @click=\"actionsOpen = !actionsOpen\" @click.outside=\"actionsOpen = false\" class=\"inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50\">\n+                            Actions\n+                            <svg class=\"w-4 h-4 ml-2\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"/>\n+                            </svg>\n+                        </button>\n+                        <div x-show=\"actionsOpen\" x-cloak class=\"absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg border border-gray-200 z-10\">\n+                            <div class=\"py-1\">\n+                                {{if eq .Task.Status \"running\"}}\n+                                <button hx-post=\"/api/vm/{{.Task.ID}}/stop\" hx-swap=\"none\" class=\"block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100\">Stop</button>\n+                                {{end}}\n+                                <button hx-delete=\"/api/vm/{{.Task.ID}}\" hx-swap=\"none\" hx-confirm=\"Are you sure you want to destroy this VM?\" class=\"block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-100\">Destroy</button>\n+                            </div>\n+                        </div>\n+                    </div>\n+                </div>\n+            </div>\n+\n+            <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n+                <!-- Resources Panel -->\n+                <div class=\"bg-white rounded-lg shadow border border-gray-200\">\n+                    <div class=\"px-4 py-3 border-b border-gray-200\">\n+                        <h2 class=\"text-lg font-medium\">Resources</h2>\n+                    </div>\n+                    <div class=\"p-4\">\n+                        <div class=\"grid grid-cols-2 gap-4\">\n+                            <div class=\"text-center p-3 bg-gray-50 rounded-lg\">\n+                                <div class=\"text-2xl font-semibold text-gray-900\">--</div>\n+                                <div class=\"text-sm text-gray-500\">CPU</div>\n+                            </div>\n+                            <div class=\"text-center p-3 bg-gray-50 rounded-lg\">\n+                                <div class=\"text-2xl font-semibold text-gray-900\">--</div>\n+                                <div class=\"text-sm text-gray-500\">Memory</div>\n+                            </div>\n+                            <div class=\"text-center p-3 bg-gray-50 rounded-lg\">\n+                                <div class=\"text-2xl font-semibold text-gray-900\">--</div>\n+                                <div class=\"text-sm text-gray-500\">Network</div>\n+                            </div>\n+                            <div class=\"text-center p-3 bg-gray-50 rounded-lg\">\n+                                <div class=\"text-2xl font-semibold text-gray-900\">--</div>\n+                                <div class=\"text-sm text-gray-500\">Disk</div>\n+                            </div>\n+                        </div>\n+                    </div>\n+                </div>\n+\n+                <!-- Logs Panel -->\n+                <div class=\"bg-white rounded-lg shadow border border-gray-200\">\n+                    <div class=\"px-4 py-3 border-b border-gray-200\">\n+                        <h2 class=\"text-lg font-medium\">Logs</h2>\n+                    </div>\n+                    <div class=\"p-4\">\n+                        <div class=\"bg-gray-50 rounded-lg p-4 text-center text-gray-500\">\n+                            Log streaming coming in Phase 2\n+                        </div>\n+                    </div>\n+                </div>\n+\n+                <!-- Details Panel -->\n+                <div class=\"bg-white rounded-lg shadow border border-gray-200\">\n+                    <div class=\"px-4 py-3 border-b border-gray-200\">\n+                        <h2 class=\"text-lg font-medium\">Details</h2>\n+                    </div>\n+                    <div class=\"p-4\">\n+                        <dl class=\"space-y-3\">\n+                            <div class=\"flex justify-between\">\n+                                <dt class=\"text-sm font-medium text-gray-500\">ID</dt>\n+                                <dd class=\"text-sm text-gray-900\">{{.Task.ID}}</dd>\n+                            </div>\n+                            <div class=\"flex justify-between\">\n+                                <dt class=\"text-sm font-medium text-gray-500\">Repository</dt>\n+                                <dd class=\"text-sm text-gray-900\">{{.Task.RepoURL}}</dd>\n+                            </div>\n+                            {{if .Task.GitRef}}\n+                            <div class=\"flex justify-between\">\n+                                <dt class=\"text-sm font-medium text-gray-500\">Git Ref</dt>\n+                                <dd class=\"text-sm text-gray-900\">{{.Task.GitRef}}</dd>\n+                            </div>\n+                            {{end}}\n+                            <div class=\"flex justify-between\">\n+                                <dt class=\"text-sm font-medium text-gray-500\">Tailscale Host</dt>\n+                                <dd class=\"text-sm text-gray-900\">{{.Task.TailscaleHost}}</dd>\n+                            </div>\n+                        </dl>\n+                    </div>\n+                </div>\n+\n+                <!-- Snapshots Panel -->\n+                <div class=\"bg-white rounded-lg shadow border border-gray-200\">\n+                    <div class=\"px-4 py-3 border-b border-gray-200 flex items-center justify-between\">\n+                        <h2 class=\"text-lg font-medium\">Snapshots</h2>\n+                        <button hx-post=\"/api/vm/{{.Task.ID}}/snapshot\" hx-swap=\"none\" class=\"inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-xs font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50\">\n+                            <svg class=\"w-4 h-4 mr-1\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 4v16m8-8H4\"/>\n+                            </svg>\n+                            Create Snapshot\n+                        </button>\n+                    </div>\n+                    <div class=\"p-4\">\n+                        {{if .Snapshots}}\n+                        <table class=\"min-w-full divide-y divide-gray-200\">\n+                            <thead class=\"bg-gray-50\">\n+                                <tr>\n+                                    <th class=\"px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\">Name</th>\n+                                    <th class=\"px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\">Label</th>\n+                                    <th class=\"px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider\">Created</th>\n+                                    <th class=\"px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider\">Actions</th>\n+                                </tr>\n+                            </thead>\n+                            <tbody class=\"bg-white divide-y divide-gray-200\">\n+                                {{range .Snapshots}}\n+                                <tr class=\"hover:bg-gray-50\">\n+                                    <td class=\"px-3 py-2 whitespace-nowrap text-sm text-gray-900\">{{.Name}}</td>\n+                                    <td class=\"px-3 py-2 whitespace-nowrap text-sm text-gray-500\">{{.Label}}</td>\n+                                    <td class=\"px-3 py-2 whitespace-nowrap text-sm text-gray-500\">{{.Created}}</td>\n+                                    <td class=\"px-3 py-2 whitespace-nowrap text-right\">\n+                                        <button hx-post=\"/api/vm/{{$.Task.ID}}/snapshot/{{.Name}}/restore\" hx-swap=\"none\" hx-confirm=\"Are you sure you want to restore this snapshot?\" class=\"text-sm text-blue-600 hover:text-blue-800\">Restore</button>\n+                                    </td>\n+                                </tr>\n+                                {{end}}\n+                            </tbody>\n+                        </table>\n+                        {{else}}\n+                        <div class=\"text-center py-6\">\n+                            <svg class=\"mx-auto h-10 w-10 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n+                                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4\"/>\n+                            </svg>\n+                            <p class=\"mt-2 text-sm text-gray-500\">No snapshots yet</p>\n+                        </div>\n+                        {{end}}\n+                    </div>\n+                </div>\n+            </div>\n+        </main>\n+    </div>\n+\n+    <script>\n+        function copySSH(host) {\n+            const sshCommand = 'ssh ' + host;\n+            navigator.clipboard.writeText(sshCommand).then(function() {\n+                alert('SSH command copied to clipboard: ' + sshCommand);\n+            }, function(err) {\n+                console.error('Could not copy text: ', err);\n+            });\n+        }\n+    </script>\n+</body>\n+</html>"
