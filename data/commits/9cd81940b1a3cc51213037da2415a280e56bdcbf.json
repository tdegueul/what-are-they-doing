{
  "message": "Adapt GitHub Actions to new structure",
  "files": [
    {
      "sha": "7f83d9b90c00f9a25e4dd8c091b82d93d84cec44",
      "filename": ".github/actions/sync/action.yaml",
      "status": "modified",
      "additions": 6,
      "deletions": 1,
      "changes": 7,
      "blob_url": "https://github.com/tenzir/news/blob/9cd81940b1a3cc51213037da2415a280e56bdcbf/.github%2Factions%2Fsync%2Faction.yaml",
      "raw_url": "https://github.com/tenzir/news/raw/9cd81940b1a3cc51213037da2415a280e56bdcbf/.github%2Factions%2Fsync%2Faction.yaml",
      "contents_url": "https://api.github.com/repos/tenzir/news/contents/.github%2Factions%2Fsync%2Faction.yaml?ref=9cd81940b1a3cc51213037da2415a280e56bdcbf",
      "patch": "@@ -10,6 +10,10 @@ inputs:\n     description: Path to changelog in source repo\n     required: false\n     default: changelog\n+  extra_paths:\n+    description: Additional paths to sync (space-separated)\n+    required: false\n+    default: \"\"\n   token:\n     description: GitHub token with workflow trigger permissions\n     required: true\n@@ -34,4 +38,5 @@ runs:\n           --repo \"${{ inputs.target }}\" \\\n           --ref \"${{ inputs.ref }}\" \\\n           --field project=\"${{ inputs.project }}\" \\\n-          --field path=\"${{ inputs.path }}\"\n+          --field path=\"${{ inputs.path }}\" \\\n+          --field extra_paths=\"${{ inputs.extra_paths }}\""
    },
    {
      "sha": "49ddb21815e6ae1e392aacc9bf098e4fe66ae943",
      "filename": ".github/workflows/sync.yaml",
      "status": "modified",
      "additions": 20,
      "deletions": 2,
      "changes": 22,
      "blob_url": "https://github.com/tenzir/news/blob/9cd81940b1a3cc51213037da2415a280e56bdcbf/.github%2Fworkflows%2Fsync.yaml",
      "raw_url": "https://github.com/tenzir/news/raw/9cd81940b1a3cc51213037da2415a280e56bdcbf/.github%2Fworkflows%2Fsync.yaml",
      "contents_url": "https://api.github.com/repos/tenzir/news/contents/.github%2Fworkflows%2Fsync.yaml?ref=9cd81940b1a3cc51213037da2415a280e56bdcbf",
      "patch": "@@ -14,6 +14,11 @@ on:\n         required: false\n         default: \"changelog\"\n         type: string\n+      extra_paths:\n+        description: \"Additional paths to sync (space-separated)\"\n+        required: false\n+        default: \"\"\n+        type: string\n \n permissions:\n   contents: write\n@@ -49,8 +54,21 @@ jobs:\n \n       - name: Sync changelog\n         run: |\n-          mkdir -p \"${{ inputs.project }}\"\n-          rsync -av --delete \"/tmp/source/${{ inputs.path }}/\" \"${{ inputs.project }}/\"\n+          mkdir -p \"${{ inputs.project }}/changelog\"\n+          rsync -av --delete \"/tmp/source/${{ inputs.path }}/\" \"${{ inputs.project }}/changelog/\"\n+\n+      - name: Sync extra paths\n+        if: inputs.extra_paths != ''\n+        run: |\n+          cd /tmp/source\n+          for pattern in ${{ inputs.extra_paths }}; do\n+            for path in $pattern; do\n+              if [[ -d \"$path\" ]]; then\n+                mkdir -p \"$GITHUB_WORKSPACE/${{ inputs.project }}/$path\"\n+                rsync -av --delete \"$path/\" \"$GITHUB_WORKSPACE/${{ inputs.project }}/$path/\"\n+              fi\n+            done\n+          done\n \n       - name: Stage changes\n         run: git add ."
    },
