      "patch": "@@ -131,7 +131,7 @@\n {\"id\":\"bd-pi3y\",\"title\":\"Test: stores batch 3 (trending, report-store, profile-store)\",\"description\":\"Third batch of test coverage for high-value untested stores:\\n- lib/discovery/trending.ts (235 lines) - trending algorithm\\n- lib/reporting/report-store.ts (387 lines) - content reporting CRUD\\n- lib/profile/profile-store.ts (523 lines) - user profiles CRUD\\nAll follow the global in-memory store pattern.\",\"status\":\"closed\",\"priority\":3,\"issue_type\":\"task\",\"assignee\":\"SwiftPuma\",\"created_at\":\"2026-02-06T01:29:56.924447621Z\",\"created_by\":\"ubuntu\",\"updated_at\":\"2026-02-06T01:33:53.313066432Z\",\"closed_at\":\"2026-02-06T01:33:53.313043138Z\",\"close_reason\":\"done\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0}\n {\"id\":\"bd-pu47\",\"title\":\"refactor: API route tests to import real core/prompts instead of mocking \u2014 test with actual registry data\",\"status\":\"open\",\"priority\":2,\"issue_type\":\"task\",\"created_at\":\"2026-02-10T00:28:49.525970377Z\",\"created_by\":\"ubuntu\",\"updated_at\":\"2026-02-10T00:32:27.256821979Z\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0,\"dependencies\":[{\"issue_id\":\"bd-pu47\",\"depends_on_id\":\"bd-9ygk\",\"type\":\"blocks\",\"created_at\":\"2026-02-10T00:30:23.008313397Z\",\"created_by\":\"ubuntu\"}],\"comments\":[{\"id\":73,\"issue_id\":\"bd-pu47\",\"author\":\"Dicklesworthstone\",\"text\":\"SCOPE: Refactor existing API route tests (prompts/route.test, health/route.test, ratings/leaderboard/route.test, share/route.test, roadmap/route.test, status/route.test) to import real @jeffreysprompts/core modules instead of vi.mock() fakes. APPROACH: Remove vi.mock('core/prompts') \u2014 import real prompts array. Tests should validate against actual registry data. Keep crypto mocking minimal (ETag hashing). BLOCKED BY bd-9ygk \u2014 need core prompts tests verifying registry integrity first.\",\"created_at\":\"2026-02-10T00:32:27Z\"}]}\n {\"id\":\"bd-r3yp\",\"title\":\"web/hooks: platform hook tests (usePWAInstall, useServiceWorker, useViewTransition, useAllRatings, use-basket, use-local-storage)\",\"status\":\"open\",\"priority\":2,\"issue_type\":\"task\",\"created_at\":\"2026-02-10T00:28:20.309606706Z\",\"created_by\":\"ubuntu\",\"updated_at\":\"2026-02-10T00:31:18.319898278Z\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0,\"comments\":[{\"id\":63,\"issue_id\":\"bd-r3yp\",\"author\":\"Dicklesworthstone\",\"text\":\"SCOPE: Test apps/web/src/hooks/ (usePWAInstall.ts, useServiceWorker.ts, useViewTransition.ts, useAllRatings.ts, use-basket.ts, use-local-storage.ts). APPROACH: renderHook + localStorage mock for storage hooks, navigator.serviceWorker mock for SW. Test: install prompt detection, SW registration, view transition API, rating aggregation, basket add/remove, localStorage sync.\",\"created_at\":\"2026-02-10T00:31:18Z\"}]}\n-{\"id\":\"bd-tk35\",\"title\":\"e2e: fix broken E2E dependencies (install @axe-core/playwright and any other missing packages)\",\"status\":\"open\",\"priority\":0,\"issue_type\":\"bug\",\"created_at\":\"2026-02-10T00:29:06.767718942Z\",\"created_by\":\"ubuntu\",\"updated_at\":\"2026-02-10T00:32:28.076730452Z\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0,\"comments\":[{\"id\":76,\"issue_id\":\"bd-tk35\",\"author\":\"Dicklesworthstone\",\"text\":\"SCOPE: Fix broken E2E test suite. Currently fails with 'Cannot find module @axe-core/playwright'. APPROACH: Run 'bun add -D @axe-core/playwright' in project root or e2e/. Check for any other missing deps. Verify 'npx playwright test --list' succeeds and lists all 83 specs. PRIORITY 0 \u2014 this blocks ALL other E2E work.\",\"created_at\":\"2026-02-10T00:32:28Z\"}]}\n+{\"id\":\"bd-tk35\",\"title\":\"e2e: fix broken E2E dependencies (install @axe-core/playwright and any other missing packages)\",\"status\":\"closed\",\"priority\":0,\"issue_type\":\"bug\",\"created_at\":\"2026-02-10T00:29:06.767718942Z\",\"created_by\":\"ubuntu\",\"updated_at\":\"2026-02-10T00:35:49.270981569Z\",\"closed_at\":\"2026-02-10T00:35:49.270962282Z\",\"close_reason\":\"Installed @axe-core/playwright v4.11.1. E2E tests now list successfully: 2136 tests in 84 files. Quality gates pass (86 unit test files, build clean).\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0,\"comments\":[{\"id\":76,\"issue_id\":\"bd-tk35\",\"author\":\"Dicklesworthstone\",\"text\":\"SCOPE: Fix broken E2E test suite. Currently fails with 'Cannot find module @axe-core/playwright'. APPROACH: Run 'bun add -D @axe-core/playwright' in project root or e2e/. Check for any other missing deps. Verify 'npx playwright test --list' succeeds and lists all 83 specs. PRIORITY 0 \u2014 this blocks ALL other E2E work.\",\"created_at\":\"2026-02-10T00:32:28Z\"}]}\n {\"id\":\"bd-tr6k\",\"title\":\"web/hooks: UI hook tests (useInView, useCountUp, useMousePosition, useReducedMotion)\",\"status\":\"open\",\"priority\":2,\"issue_type\":\"task\",\"created_at\":\"2026-02-10T00:28:19.840200675Z\",\"created_by\":\"ubuntu\",\"updated_at\":\"2026-02-10T00:31:17.864329011Z\",\"source_repo\":\".\",\"compaction_level\":0,\"original_size\":0,\"comments\":[{\"id\":60,\"issue_id\":\"bd-tr6k\",\"author\":\"Dicklesworthstone\",\"text\":\"SCOPE: Test apps/web/src/hooks/ (useInView.ts, useCountUp.ts, useMousePosition.ts, useReducedMotion.ts). APPROACH: renderHook from @testing-library. useInView \u2014 test intersection observer setup. useCountUp \u2014 test animation frame counting with fake timers. useMousePosition \u2014 simulate mouse events. useReducedMotion \u2014 test matchMedia mock.\",\"created_at\":\"2026-02-10T00:31:17Z\"}]}\n {\"id\":\"bd-tujz\",\"title\":\"Accessibility: ARIA + keyboard nav for review components\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"created_at\":\"2026-02-06T00:24:38.368038105Z\",\"created_by\":\"ubuntu\",\"updated_at\":\"2026-02-06T00:27:20